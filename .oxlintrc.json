{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "docs/assets/js/beautifuljekyll.js",
    "docs/assets/js/staticman.js",
    "docs/assets/vendor/**"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": ["error", { "caughtErrors": "none" }],
    "unicorn/no-new-array": "off",
    "unicorn/no-empty-file": "off"
  }
}
