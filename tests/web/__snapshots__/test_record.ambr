                          &mdash;
                      </td>
                      <td data-label="User Name">
                          <a href="/u/102">user2</a>
                      </td>
                      <td data-label="User ID">
                          <span class="id-copy">
                              <span class="user-id">102</span>
                              <button type="button" class="copy" data-copy="102" title="Copy User ID">⎘</button>
                          </span>
                      </td>
                      <td data-label="Jump"><a href="https://discord.com/channels/201/301/903" class="button">Jump&nbsp;to&nbsp;game</a></td>
                  </tr>
                  
                  <tr>
                      <td data-label="Game"><a href="/game/2">SB#2</a></td>
                      
                      <td data-label="Time" class="timestamp">1577836800000.0</td>
                      
                      <td data-label="Format">Standard</td>
                      <td data-label="Seats">2</td>
                      <td data-label="Bracket">None</td>
                      <td data-label="Locale">en</td>
                      <td data-label="Link">
                          &mdash;
                      </td>
                      <td data-label="User Name">
                          <a href="/u/101">user1</a>
                      </td>
                      <td data-label="User ID">
                          <span class="id-copy">
                              <span class="user-id">101</span>
                              <button type="button" class="copy" data-copy="101" title="Copy User ID">⎘</button>
                          </span>
                      </td>
                      <td data-label="Jump"><a href="https://discord.com/channels/201/301/902" class="button">Jump&nbsp;to&nbsp;game</a></td>
                  </tr>
                  
                  <tr>
                      <td data-label="Game"><a href="/game/2">SB#2</a></td>
                      
                      <td data-label="Time" class="timestamp">1577836800000.0</td>
                      
                      <td data-label="Format">Standard</td>
                      <td data-label="Seats">2</td>
                      <td data-label="Bracket">None</td>
                      <td data-label="Locale">en</td>
                      <td data-label="Link">
                          &mdash;
                      </td>
                      <td data-label="User Name">
                          <a href="/u/102">user2</a>
                      </td>
                      <td data-label="User ID">
                          <span class="id-copy">
                              <span class="user-id">102</span>
                              <button type="button" class="copy" data-copy="102" title="Copy User ID">⎘</button>
                          </span>
                      </td>
                      <td data-label="Jump"><a href="https://discord.com/channels/201/301/902" class="button">Jump&nbsp;to&nbsp;game</a></td>
                  </tr>
                  
                  <tr>
                      <td data-label="Game"><a href="/game/1">SB#1</a></td>
                      
                      <td data-label="Time" class="timestamp">1577836800000.0</td>
                      
                      <td data-label="Format">Modern</td>
                      <td data-label="Seats">2</td>
                      <td data-label="Bracket">None</td>
                      <td data-label="Locale">en</td>
                      <td data-label="Link">
                          &mdash;
                      </td>
                      <td data-label="User Name">
                          <a href="/u/101">user1</a>
                      </td>
                      <td data-label="User ID">
                          <span class="id-copy">
                              <span class="user-id">101</span>
                              <button type="button" class="copy" data-copy="101" title="Copy User ID">⎘</button>
                          </span>
                      </td>
                      <td data-label="Jump"><a href="https://discord.com/channels/201/301/901" class="button">Jump&nbsp;to&nbsp;game</a></td>
                  </tr>
                  
                  <tr>
                      <td data-label="Game"><a href="/game/1">SB#1</a></td>
                      
                      <td data-label="Time" class="timestamp">1577836800000.0</td>
                      
                      <td data-label="Format">Modern</td>
                      <td data-label="Seats">2</td>
                      <td data-label="Bracket">None</td>
                      <td data-label="Locale">en</td>
                      <td data-label="Link">
                          &mdash;
                      </td>
                      <td data-label="User Name">
                          <a href="/u/102">user2</a>
                      </td>
                      <td data-label="User ID">
                          <span class="id-copy">
                              <span class="user-id">102</span>
                              <button type="button" class="copy" data-copy="102" title="Copy User ID">⎘</button>
                          </span>
                      </td>
                      <td data-label="Jump"><a href="https://discord.com/channels/201/301/901" class="button">Jump&nbsp;to&nbsp;game</a></td>
                  </tr>
                  
              </tbody>
          </table>
          
      </div>
  </div>
  
  
          
          <div class="actions">
              <a href="/g/201/c/301/export.csv" class="button">Export all (CSV)</a>
              
              
          </div>
          
  
          <div class="footer">
              <p>Generated by <a href="https://spellbot.io/">SpellBot</a></p>
          </div>
      </div>
  
      <script
          src="https://cdn.jsdelivr.net/npm/js-cookie@3.0.1/dist/js.cookie.min.js"
          integrity="sha256-0H3Nuz3aug3afVbUlsu12Puxva3CP4EhJtPExqs54Vg="
          crossorigin="anonymous"></script>
  
      <script
          src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"
          integrity="sha512-qTXRIMyZIFb8iQcfjXWCO8+M5Tbc38Qi5WzdPOYZHIlZpzBHG3L3by84BBBOiRGiEb7KKtAOAs5qYdUiZiQNNQ=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer"></script>
  
      <script
          src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.34/moment-timezone-with-data.js"
          integrity="sha512-oqSECbLRRAy3Sq2tJ0RmzbqXHprFS+n7WapvpI1t0V7CtV4vghscIQ8MYoQo6tp4MrJmih4SlOaYuCkPRi3j6A=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer"></script>
  
      <script>
          const timezoneOffsetCookie = 'timezone_offset';
          const timezoneNameCookie = 'timezone_name';
          const testCookie = 'test';
          const lang = navigator.languages != undefined ?
                          navigator.languages[0] :
                          undefined;
          const today = new Date();
          const zone = moment.tz.guess();
          const offset = today.getTimezoneOffset();
  
          if (!Cookies.get(timezoneOffsetCookie) || !Cookies.get(timezoneNameCookie)) {
              Cookies.set(testCookie, true);
              if (Cookies.get(testCookie)) {
                  Cookies.set(testCookie, null);
                  Cookies.set(timezoneOffsetCookie, offset);
                  Cookies.set(timezoneNameCookie, zone);
                  location.reload();
              }
          } else {
              const storedOffset = parseInt(Cookies.get(timezoneOffsetCookie));
              const storedZone = Cookies.get(timezoneNameCookie);
              if (storedOffset !== offset || storedZone !== zone) {
                  Cookies.set(timezoneOffsetCookie, offset);
                  Cookies.set(timezoneNameCookie, zone);
                  location.reload();
              }
          }
  
          function humanize_timestamp(ts) {
              const options = {
                  weekday: 'long',
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                  hour12: true,
                  hour: 'numeric',
                  minute: 'numeric',
                  timeZoneName: 'short',
              };
              return (new Date(ts)).toLocaleDateString(lang, options);
          }
  
          Array.from(document.getElementsByClassName('timestamp')).forEach((el) => {
              el.innerHTML = humanize_timestamp(Number(el.innerHTML));
          });
  
          // Make `<select multiple>` toggle on plain click instead of requiring
          // Ctrl/Cmd-click. Intercept `mousedown` on each option, suppress the
          // native replace-selection behavior, and flip the option's selected
          // state so single clicks add or remove items from the selection.
          document.querySelectorAll('select[multiple]').forEach((select) => {
              select.addEventListener('mousedown', (event) => {
                  if (event.target.tagName !== 'OPTION') return;
                  event.preventDefault();
                  event.target.selected = !event.target.selected;
                  select.focus();
                  select.dispatchEvent(new Event('change', { bubbles: true }));
              });
          });
  
          document.querySelectorAll('.copy').forEach((el) => {
              el.addEventListener('click', async (event) => {
                  event.preventDefault();
                  const value = el.dataset.copy;
                  let ok = false;
                  try {
                      await navigator.clipboard.writeText(value);
                      ok = true;
                  } catch (e) {
                      const temp = document.createElement('input');
                      temp.value = value;
                      document.body.appendChild(temp);
                      temp.select();
                      try { ok = document.execCommand('copy'); } catch (e2) { ok = false; }
                      temp.remove();
                  }
                  const orig = el.textContent;
                  el.textContent = ok ? '\u2713' : '\u2717';
                  el.classList.add('copied');
                  setTimeout(() => {
                      el.textContent = orig;
                      el.classList.remove('copied');
                  }, 1200);
              });
          });
      </script>
  </body>
  </html>
  '''
# ---
# name: TestWebRecord.test_channel_record_no_plays
  '''
  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
      <title>Channel Records — #channel</title>
      <meta name="author" content="Amy Troschinetz">
      <meta name="description" content="SpellBot game records">
      <meta name="theme-color" content="#5A3EFD">
      <link rel="icon" type="image/x-icon" href="https://spellbot.io/favicon.ico">
      <style>
          /* Shared foundation for every SpellBot web page: the reset, design tokens, and
     the page-level body/link/container rules. Each page template includes this
     first, then its page-specific stylesheet. Keep colors and shared primitives
     here so the pages can't drift apart. */
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  :root {
    --brand-purple: #5a3efd;
    --brand-purple-dark: #3f2bcc;
    --brand-orange: #f6ad4b;
    --brand-orange-dark: #c98a2f;
    --link: #ffb342;
    --link-hover: #ffd160;
    --accent: #818cf8;
    --text: #e6e8ee;
    --muted: #b6bdcb;
    --card-bg: #232a39;
    --card-bg-hover: #2a3243;
    --page-bg: #1a202c;
    --page-text: #ffffff;
    --page-muted: #a0aec0;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: #333;
    --shadow: 0 4px 18px rgba(0, 0, 0, 0.35);
    --danger-bg: #3f1e1e;
    --danger-bg-hover: #552a2a;
    --danger-border: #5a2a2a;
    --danger-text: #fca5a5;
  }
  
  body {
    font-family:
      "Verdana",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    background: var(--page-bg);
    color: var(--page-text);
    min-height: 100vh;
    padding: 2rem 1rem 3rem;
    line-height: 1.45;
  }
  
  a,
  a:visited,
  a:active {
    color: var(--link);
    text-decoration: none;
  }
  a:hover {
    color: var(--link-hover);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
          /* Detail pages (guild, channel, user, game). Shared reset, tokens, body, links,
     and .container live in base.css, which is included before this file. */
  
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-strong);
  }
  .header > a {
    display: inline-flex;
  }
  .header img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
  }
  .header .titles {
    flex: 1;
    min-width: 0;
  }
  .header h1 {
    font-size: 1.75rem;
    font-weight: 600;
    word-break: break-word;
  }
  .header .subtitle {
    font-size: 0.85rem;
    color: var(--page-muted);
    margin-top: 0.25rem;
  }
  /* The user and guild subtitles carry extra inline content — a monospace ID span
     and, on the user page, a copy button — whose natural line boxes are ~1px taller
     than the plain-text subtitles on the channel and game pages. Pin their line
     height so every detail page's header (and its divider rule) lands in the same
     spot regardless of subtitle content. */
  .header .subtitle .user-id {
    display: inline-block;
    line-height: 1.2;
    vertical-align: middle;
  }
  .header .subtitle .copy {
    width: 1.1rem;
    height: 1.1rem;
  }
  .header-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .header-nav .button {
    min-width: 0;
    font-size: 0.8rem;
    background: var(--card-bg);
    border-color: var(--border-strong);
    color: var(--page-text);
  }
  
  .section {
    margin-bottom: 1.5rem;
  }
  .section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .section-head h2 {
    margin-bottom: 0;
  }
  
  .award-summary {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .award-summary li {
    padding: 0.35rem 0;
  }
  .award-summary li + li {
    border-top: 1px solid var(--border);
  }
  
  .award-card {
    padding: 0;
    margin-bottom: 0.75rem;
  }
  .award-card-summary {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .award-card-summary::-webkit-details-marker {
    display: none;
  }
  .award-card-summary::before {
    content: "\25B6";
    font-size: 0.7em;
    color: var(--accent);
    transition: transform 0.15s ease;
  }
  .award-card[open] > .award-card-summary::before {
    transform: rotate(90deg);
  }
  .award-card[open] > .award-card-summary {
    border-bottom: 1px solid var(--border);
  }
  .award-card-body {
    padding: 1.25rem;
  }
  .award-add-card {
    margin-top: 0.75rem;
  }
  
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    box-shadow: var(--shadow);
  }
  
  /* Space sibling cards within a section (e.g. settings + "forget" cards). */
  .card + .card {
    margin-top: 0.75rem;
  }
  
  .empty {
    color: var(--muted);
    font-style: italic;
    padding: 0.5rem 0;
  }
  
  .owner-promote-status {
    margin-bottom: 0.75rem;
  }
  .owner-promote-status strong {
    color: var(--accent);
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
  }
  table th,
  table td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    vertical-align: top;
  }
  table thead th {
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  table tbody tr + tr td {
    border-top: 1px solid var(--border);
  }
  table tbody tr:nth-child(even) td {
    background: var(--page-bg);
  }
  table tbody td {
    color: var(--text);
    font-size: 0.9rem;
  }
  
  .user-id {
    font-family: monospace;
    color: var(--muted);
    font-size: 0.85rem;
  }
  
  .id-copy {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  
  .copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-left: 0.35rem;
    border-radius: 4px;
    background: var(--page-bg);
    border: 1px solid var(--border);
    color: var(--accent);
    font-size: 0.75rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
    vertical-align: middle;
  }
  .copy:hover {
    background: var(--card-bg-hover);
  }
  .copy.copied {
    color: #4ade80;
  }
  
  .players {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .player {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .player .name {
    color: var(--text);
  }
  
  .jumps {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .button {
    display: inline-block;
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    min-width: 6.5rem;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }
  .button:hover {
    background: var(--card-bg-hover);
    border-color: var(--accent);
    color: var(--accent);
  }
  .button-danger {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: var(--danger-border);
  }
  .button-danger:hover {
    background: var(--danger-bg-hover);
    border-color: var(--danger-border);
    color: var(--danger-text);
  }
  .award-error {
    background: var(--danger-bg);
    color: var(--danger-text);
    border: 1px solid var(--danger-border);
    margin-bottom: 0.75rem;
  }
  .block-add-form {
    margin-top: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  a.button,
  a.button:visited,
  a.button:active {
    color: var(--text);
  }
  a.button:hover {
    color: var(--accent);
    text-decoration: none;
  }
  
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    justify-content: flex-end;
  }
  
  .filters {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }
  .filters .row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
  }
  .filters .field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1 1 12rem;
    min-width: 10rem;
  }
  .filters label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--page-muted);
  }
  .filters input,
  .filters select {
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
  }
  .filters select[multiple] {
    min-height: 5.5rem;
  }
  .filters .actions {
    margin-top: 0.75rem;
    justify-content: flex-start;
  }
  
  /* One setting per row, stacked: the name, its help text directly beneath the name,
     then the control. */
  .settings-form .grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .settings-form .field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .settings-form label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }
  .settings-form input[type="text"],
  .settings-form input[type="number"],
  .settings-form select {
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
  }
  .settings-form .toggle-row {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
  .settings-form .toggle-row label {
    text-transform: none;
    letter-spacing: normal;
    font-size: 0.85rem;
    color: var(--text);
  }
  .settings-form .toggle-row input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--brand-purple);
    cursor: pointer;
  }
  .settings-form .hint {
    color: var(--muted);
    font-size: 0.8rem;
  }
  
  .block-list > summary {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5rem;
    cursor: pointer;
  }
  .block-list[open] > summary {
    margin-bottom: 0.75rem;
  }
  
  .motd-help {
    margin-top: 0.35rem;
    font-size: 0.8rem;
  }
  .motd-help summary {
    color: var(--accent);
    cursor: pointer;
  }
  .motd-help .hint {
    margin: 0.35rem 0;
  }
  .motd-placeholders {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--muted);
  }
  .motd-placeholders code {
    background: var(--page-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.3rem;
    font-size: 0.72rem;
    color: var(--text);
  }
  
  .login-prompt {
    margin: 0;
  }
  .login-prompt .button {
    margin-left: 0.5rem;
  }
  .settings-form .actions {
    justify-content: flex-start;
  }
  
  table thead th .sort {
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
  }
  table thead th .sort:hover {
    color: var(--accent);
  }
  table thead th .sort .arrow {
    margin-left: 0.25rem;
    color: var(--accent);
  }
  
  .count {
    color: var(--muted);
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.875rem;
    color: var(--muted);
  }
  
  @media (max-width: 720px) {
    body {
      padding: 1rem;
    }
    .header {
      flex-direction: column;
      align-items: flex-start;
    }
    table thead {
      display: none;
    }
    table,
    table tbody,
    table tr,
    table td {
      display: block;
      width: 100%;
    }
    table tbody tr {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }
    table tbody tr + tr td {
      border-top: none;
    }
    table tbody td {
      padding: 0.5rem 0.75rem;
    }
    table tbody td::before {
      content: attr(data-label);
      display: block;
      color: var(--muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.15rem;
    }
  }
      </style>
  </head>
  <body>
      <div class="container">
          <div class="header">
              <a href="https://spellbot.io/">
                  <img alt="SpellBot" src="https://spellbot.io/assets/img/avatar-icon.png">
              </a>
              <div class="titles">
                  <h1>Channel Records: #channel</h1>
                  
  <div class="subtitle">
      <a href="/g/201">guild</a>
      <a href="https://discord.com/channels/201/101" class="button">Jump&nbsp;to&nbsp;channel</a>
  </div>
  
              </div>
              <nav class="header-nav">
                  <a href="/queues" class="button">Active Queues</a>
                  
              </nav>
          </div>
  
          
  <div class="section">
      <div class="card">
          <p class="login-prompt">
              Moderators can manage this channel&#39;s settings here.
              <a href="/queues/login?next=%2Fg%2F201%2Fc%2F101" class="button">Log in with Discord</a>
          </p>
      </div>
  </div>
  <div class="section">
      <h2>Games <span class="count">(0 matching)</span></h2>
      
  <form method="get" class="filters">
      <div class="row">
          <div class="field">
              <label for="f-with-player">Player (name or ID)</label>
              <input type="text" id="f-with-player" name="with_player" value="" placeholder="e.g. amy or 12345">
          </div>
          
          <div class="field">
              <label for="f-from">From</label>
              <input type="date" id="f-from" name="from" value="">
          </div>
          <div class="field">
              <label for="f-to">To</label>
              <input type="date" id="f-to" name="to" value="">
          </div>
      </div>
      <div class="row">
          <div class="field">
              <label for="f-formats">Format(s)</label>
              <select id="f-formats" name="formats" multiple size="6">
                  
                  <option value="1" >Commander</option>
                  
                  <option value="18" >Commander Precons</option>
                  
                  <option value="15" >EDH Low</option>
                  
                  <option value="14" >EDH Mid</option>
                  
                  <option value="13" >EDH High</option>
                  
                  <option value="12" >EDH Max</option>
                  
                  <option value="16" >EDH Battlecruiser</option>
                  
                  <option value="17" >Planechase</option>
                  
                  <option value="9" >Two Headed Giant</option>
                  
                  <option value="8" >Brawl (Multiplayer)</option>
                  
                  <option value="21" >cEDH</option>
                  
                  <option value="23" >Pauper EDH</option>
                  
                  <option value="19" >Oathbreaker</option>
                  
                  <option value="22" >Archenemy</option>
                  
                  <option value="24" >Horde Magic</option>
                  
                  <option value="20" >Duel Commander</option>
                  
                  <option value="2" >Standard</option>
                  
                  <option value="4" >Modern</option>
                  
                  <option value="11" >Pioneer</option>
                  
                  <option value="10" >Pauper</option>
                  
                  <option value="6" >Legacy</option>
                  
                  <option value="5" >Vintage</option>
                  
                  <option value="3" >Sealed</option>
                  
                  <option value="7" >Brawl (Two Players)</option>
                  
              </select>
          </div>
          <div class="field">
              <label for="f-brackets">Bracket(s)</label>
              <select id="f-brackets" name="brackets" multiple size="6">
                  
                  <option value="1" >None</option>
                  
                  <option value="2" >Bracket 1: Exhibition</option>
                  
                  <option value="3" >Bracket 2: Core</option>
                  
                  <option value="4" >Bracket 3: Upgraded</option>
                  
                  <option value="5" >Bracket 4: Optimized</option>
                  
                  <option value="6" >Bracket 5: Competitive</option>
                  
              </select>
          </div>
      </div>
      <div class="actions">
          <button type="submit" class="button">Apply filters</button>
          <a href="?" class="button">Reset</a>
      </div>
  </form>
  
      <div class="card">
          
          <div class="empty">No games found for this channel.</div>
          
      </div>
  </div>
  
  
          
          <div class="actions">
              <a href="/g/201/c/101/export.csv" class="button">Export all (CSV)</a>
              
              
          </div>
          
  
          <div class="footer">
              <p>Generated by <a href="https://spellbot.io/">SpellBot</a></p>
          </div>
      </div>
  
      <script
          src="https://cdn.jsdelivr.net/npm/js-cookie@3.0.1/dist/js.cookie.min.js"
          integrity="sha256-0H3Nuz3aug3afVbUlsu12Puxva3CP4EhJtPExqs54Vg="
          crossorigin="anonymous"></script>
  
      <script
          src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"
          integrity="sha512-qTXRIMyZIFb8iQcfjXWCO8+M5Tbc38Qi5WzdPOYZHIlZpzBHG3L3by84BBBOiRGiEb7KKtAOAs5qYdUiZiQNNQ=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer"></script>
  
      <script
          src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.34/moment-timezone-with-data.js"
          integrity="sha512-oqSECbLRRAy3Sq2tJ0RmzbqXHprFS+n7WapvpI1t0V7CtV4vghscIQ8MYoQo6tp4MrJmih4SlOaYuCkPRi3j6A=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer"></script>
  
      <script>
          const timezoneOffsetCookie = 'timezone_offset';
          const timezoneNameCookie = 'timezone_name';
          const testCookie = 'test';
          const lang = navigator.languages != undefined ?
                          navigator.languages[0] :
                          undefined;
          const today = new Date();
          const zone = moment.tz.guess();
          const offset = today.getTimezoneOffset();
  
          if (!Cookies.get(timezoneOffsetCookie) || !Cookies.get(timezoneNameCookie)) {
              Cookies.set(testCookie, true);
              if (Cookies.get(testCookie)) {
                  Cookies.set(testCookie, null);
                  Cookies.set(timezoneOffsetCookie, offset);
                  Cookies.set(timezoneNameCookie, zone);
                  location.reload();
              }
          } else {
              const storedOffset = parseInt(Cookies.get(timezoneOffsetCookie));
              const storedZone = Cookies.get(timezoneNameCookie);
              if (storedOffset !== offset || storedZone !== zone) {
                  Cookies.set(timezoneOffsetCookie, offset);
                  Cookies.set(timezoneNameCookie, zone);
                  location.reload();
              }
          }
  
          function humanize_timestamp(ts) {
              const options = {
                  weekday: 'long',
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                  hour12: true,
                  hour: 'numeric',
                  minute: 'numeric',
                  timeZoneName: 'short',
              };
              return (new Date(ts)).toLocaleDateString(lang, options);
          }
  
          Array.from(document.getElementsByClassName('timestamp')).forEach((el) => {
              el.innerHTML = humanize_timestamp(Number(el.innerHTML));
          });
  
          // Make `<select multiple>` toggle on plain click instead of requiring
          // Ctrl/Cmd-click. Intercept `mousedown` on each option, suppress the
          // native replace-selection behavior, and flip the option's selected
          // state so single clicks add or remove items from the selection.
          document.querySelectorAll('select[multiple]').forEach((select) => {
              select.addEventListener('mousedown', (event) => {
                  if (event.target.tagName !== 'OPTION') return;
                  event.preventDefault();
                  event.target.selected = !event.target.selected;
                  select.focus();
                  select.dispatchEvent(new Event('change', { bubbles: true }));
              });
          });
  
          document.querySelectorAll('.copy').forEach((el) => {
              el.addEventListener('click', async (event) => {
                  event.preventDefault();
                  const value = el.dataset.copy;
                  let ok = false;
                  try {
                      await navigator.clipboard.writeText(value);
                      ok = true;
                  } catch (e) {
                      const temp = document.createElement('input');
                      temp.value = value;
                      document.body.appendChild(temp);
                      temp.select();
                      try { ok = document.execCommand('copy'); } catch (e2) { ok = false; }
                      temp.remove();
                  }
                  const orig = el.textContent;
                  el.textContent = ok ? '\u2713' : '\u2717';
                  el.classList.add('copied');
                  setTimeout(() => {
                      el.textContent = orig;
                      el.classList.remove('copied');
                  }, 1200);
              });
          });
      </script>
  </body>
  </html>
  '''
# ---
# name: TestWebRecord.test_channel_record_with_cookies
  '''
  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
      <title>Channel Records — #channel</title>
      <meta name="author" content="Amy Troschinetz">
      <meta name="description" content="SpellBot game records">
      <meta name="theme-color" content="#5A3EFD">
      <link rel="icon" type="image/x-icon" href="https://spellbot.io/favicon.ico">
      <style>
          /* Shared foundation for every SpellBot web page: the reset, design tokens, and
     the page-level body/link/container rules. Each page template includes this
     first, then its page-specific stylesheet. Keep colors and shared primitives
     here so the pages can't drift apart. */
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  :root {
    --brand-purple: #5a3efd;
    --brand-purple-dark: #3f2bcc;
    --brand-orange: #f6ad4b;
    --brand-orange-dark: #c98a2f;
    --link: #ffb342;
    --link-hover: #ffd160;
    --accent: #818cf8;
    --text: #e6e8ee;
    --muted: #b6bdcb;
    --card-bg: #232a39;
    --card-bg-hover: #2a3243;
    --page-bg: #1a202c;
    --page-text: #ffffff;
    --page-muted: #a0aec0;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: #333;
    --shadow: 0 4px 18px rgba(0, 0, 0, 0.35);
    --danger-bg: #3f1e1e;
    --danger-bg-hover: #552a2a;
    --danger-border: #5a2a2a;
    --danger-text: #fca5a5;
  }
  
  body {
    font-family:
      "Verdana",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    background: var(--page-bg);
    color: var(--page-text);
    min-height: 100vh;
    padding: 2rem 1rem 3rem;
    line-height: 1.45;
  }
  
  a,
  a:visited,
  a:active {
    color: var(--link);
    text-decoration: none;
  }
  a:hover {
    color: var(--link-hover);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
          /* Detail pages (guild, channel, user, game). Shared reset, tokens, body, links,
     and .container live in base.css, which is included before this file. */
  
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-strong);
  }
  .header > a {
    display: inline-flex;
  }
  .header img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
  }
  .header .titles {
    flex: 1;
    min-width: 0;
  }
  .header h1 {
    font-size: 1.75rem;
    font-weight: 600;
    word-break: break-word;
  }
  .header .subtitle {
    font-size: 0.85rem;
    color: var(--page-muted);
    margin-top: 0.25rem;
  }
  /* The user and guild subtitles carry extra inline content — a monospace ID span
     and, on the user page, a copy button — whose natural line boxes are ~1px taller
     than the plain-text subtitles on the channel and game pages. Pin their line
     height so every detail page's header (and its divider rule) lands in the same
     spot regardless of subtitle content. */
  .header .subtitle .user-id {
    display: inline-block;
    line-height: 1.2;
    vertical-align: middle;
  }
  .header .subtitle .copy {
    width: 1.1rem;
    height: 1.1rem;
  }
  .header-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .header-nav .button {
    min-width: 0;
    font-size: 0.8rem;
    background: var(--card-bg);
    border-color: var(--border-strong);
    color: var(--page-text);
  }
  
  .section {
    margin-bottom: 1.5rem;
  }
  .section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .section-head h2 {
    margin-bottom: 0;
  }
  
  .award-summary {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .award-summary li {
    padding: 0.35rem 0;
  }
  .award-summary li + li {
    border-top: 1px solid var(--border);
  }
  
  .award-card {
    padding: 0;
    margin-bottom: 0.75rem;
  }
  .award-card-summary {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .award-card-summary::-webkit-details-marker {
    display: none;
  }
  .award-card-summary::before {
    content: "\25B6";
    font-size: 0.7em;
    color: var(--accent);
    transition: transform 0.15s ease;
  }
  .award-card[open] > .award-card-summary::before {
    transform: rotate(90deg);
  }
  .award-card[open] > .award-card-summary {
    border-bottom: 1px solid var(--border);
  }
  .award-card-body {
    padding: 1.25rem;
  }
  .award-add-card {
    margin-top: 0.75rem;
  }
  
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    box-shadow: var(--shadow);
  }
  
  /* Space sibling cards within a section (e.g. settings + "forget" cards). */
  .card + .card {
    margin-top: 0.75rem;
  }
  
  .empty {
    color: var(--muted);
    font-style: italic;
    padding: 0.5rem 0;
  }
  
  .owner-promote-status {
    margin-bottom: 0.75rem;
  }
  .owner-promote-status strong {
    color: var(--accent);
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
  }
  table th,
  table td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    vertical-align: top;
  }
  table thead th {
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  table tbody tr + tr td {
    border-top: 1px solid var(--border);
  }
  table tbody tr:nth-child(even) td {
    background: var(--page-bg);
  }
  table tbody td {
    color: var(--text);
    font-size: 0.9rem;
  }
  
  .user-id {
    font-family: monospace;
    color: var(--muted);
    font-size: 0.85rem;
  }
  
  .id-copy {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  
  .copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-left: 0.35rem;
    border-radius: 4px;
    background: var(--page-bg);
    border: 1px solid var(--border);
    color: var(--accent);
    font-size: 0.75rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
    vertical-align: middle;
  }
  .copy:hover {
    background: var(--card-bg-hover);
  }
  .copy.copied {
    color: #4ade80;
  }
  
  .players {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .player {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .player .name {
    color: var(--text);
  }
  
  .jumps {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .button {
    display: inline-block;
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    min-width: 6.5rem;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }
  .button:hover {
    background: var(--card-bg-hover);
    border-color: var(--accent);
    color: var(--accent);
  }
  .button-danger {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: var(--danger-border);
  }
  .button-danger:hover {
    background: var(--danger-bg-hover);
    border-color: var(--danger-border);
    color: var(--danger-text);
  }
  .award-error {
    background: var(--danger-bg);
    color: var(--danger-text);
    border: 1px solid var(--danger-border);
    margin-bottom: 0.75rem;
  }
  .block-add-form {
    margin-top: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  a.button,
  a.button:visited,
  a.button:active {
    color: var(--text);
  }
  a.button:hover {
    color: var(--accent);
    text-decoration: none;
  }
  
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    justify-content: flex-end;
  }
  
  .filters {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }
  .filters .row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
  }
  .filters .field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1 1 12rem;
    min-width: 10rem;
  }
  .filters label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--page-muted);
  }
  .filters input,
  .filters select {
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
  }
  .filters select[multiple] {
    min-height: 5.5rem;
  }
  .filters .actions {
    margin-top: 0.75rem;
    justify-content: flex-start;
  }
  
  /* One setting per row, stacked: the name, its help text directly beneath the name,
     then the control. */
  .settings-form .grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .settings-form .field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .settings-form label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }
  .settings-form input[type="text"],
  .settings-form input[type="number"],
  .settings-form select {
    background: var(--page-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
  }
  .settings-form .toggle-row {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
  .settings-form .toggle-row label {
    text-transform: none;
    letter-spacing: normal;
    font-size: 0.85rem;
    color: var(--text);
  }
  .settings-form .toggle-row input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--brand-purple);
    cursor: pointer;
  }
  .settings-form .hint {
    color: var(--muted);
    font-size: 0.8rem;
  }
  
  .block-list > summary {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5rem;
    cursor: pointer;
  }
  .block-list[open] > summary {
    margin-bottom: 0.75rem;
  }
  
  .motd-help {
    margin-top: 0.35rem;
    font-size: 0.8rem;
  }
  .motd-help summary {
    color: var(--accent);
    cursor: pointer;
  }
  .motd-help .hint {
    margin: 0.35rem 0;
  }
  .motd-placeholders {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--muted);
  }
  .motd-placeholders code {
    background: var(--page-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.3rem;
    font-size: 0.72rem;
    color: var(--text);
  }
  
  .login-prompt {
    margin: 0;
  }
  .login-prompt .button {
    margin-left: 0.5rem;
  }
  .settings-form .actions {
    justify-content: flex-start;
  }
  
  table thead th .sort {
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
  }
  table thead th .sort:hover {
    color: var(--accent);
  }
  table thead th .sort .arrow {
    margin-left: 0.25rem;
    color: var(--accent);
  }
  
  .count {
    color: var(--muted);
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.875rem;
    color: var(--muted);
  }
  
  @media (max-width: 720px) {
    body {
      padding: 1rem;
    }
    .header {
      flex-direction: column;
      align-items: flex-start;
    }
    table thead {
      display: none;
    }
    table,
    table tbody,
    table tr,
    table td {
      display: block;
      width: 100%;
    }
    table tbody tr {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }
    table tbody tr + tr td {
      border-top: none;
    }
    table tbody td {
      padding: 0.5rem 0.75rem;
    }
    table tbody td::before {
      content: attr(data-label);
      display: block;
      color: var(--muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.15rem;
    }
  }
      </style>
  </head>
  <body>
      <div class="container">
          <div class="header">
              <a href="https://spellbot.io/">
                  <img alt="SpellBot" src="https://spellbot.io/assets/img/avatar-icon.png">
              </a>
              <div class="titles">
                  <h1>Channel Records: #channel</h1>
                  
  <div class="subtitle">
      <a href="/g/201">guild</a>
      <a href="https://discord.com/channels/201/301" class="button">Jump&nbsp;to&nbsp;channel</a>
  </div>
  
              </div>
              <nav class="header-nav">
                  <a href="/queues" class="button">Active Queues</a>
                  
              </nav>
          </div>
  
          
  <div class="section">
      <div class="card">
          <p class="login-prompt">
              Moderators can manage this channel&#39;s settings here.
              <a href="/queues/login?next=%2Fg%2F201%2Fc%2F301" class="button">Log in with Discord</a>
          </p>
      </div>
  </div>
  <div class="section">
      <h2>Games <span class="count">(3 matching)</span></h2>
      
  <form method="get" class="filters">
      <div class="row">
          <div class="field">
              <label for="f-with-player">Player (name or ID)</label>
              <input type="text" id="f-with-player" name="with_player" value="" placeholder="e.g. amy or 12345">
          </div>
          
          <div class="field">
              <label for="f-from">From</label>
              <input type="date" id="f-from" name="from" value="">
          </div>
          <div class="field">
              <label for="f-to">To</label>
              <input type="date" id="f-to" name="to" value="">
          </div>
      </div>
      <div class="row">
          <div class="field">
              <label for="f-formats">Format(s)</label>
              <select id="f-formats" name="formats" multiple size="6">
                  
                  <option value="1" >Commander</option>
                  
                  <option value="18" >Commander Precons</option>
                  
                  <option value="15" >EDH Low</option>
                  
                  <option value="14" >EDH Mid</option>
                  
                  <option value="13" >EDH High</option>
                  
                  <option value="12" >EDH Max</option>
                  
                  <option value="16" >EDH Battlecruiser</option>
                  
                  <option value="17" >Planechase</option>
                  
                  <option value="9" >Two Headed Giant</option>
                  
                  <option value="8" >Brawl (Multiplayer)</option>
                  
                  <option value="21" >cEDH</option>
                  
                  <option value="23" >Pauper EDH</option>
                  
                  <option value="19" >Oathbreaker</option>
                  
                  <option value="22" >Archenemy</option>
                  
                  <option value="24" >Horde Magic</option>
                  
                  <option value="20" >Duel Commander</option>
                  
                  <option value="2" >Standard</option>
                  
                  <option value="4" >Modern</option>
                  
                  <option value="11" >Pioneer</option>
                  
                  <option value="10" >Pauper</option>
                  
                  <option value="6" >Legacy</option>
                  
                  <option value="5" >Vintage</option>
                  
                  <option value="3" >Sealed</option>
                  
                  <option value="7" >Brawl (Two Players)</option>
                  
              </select>
          </div>
          <div class="field">
              <label for="f-brackets">Bracket(s)</label>
              <select id="f-brackets" name="brackets" multiple size="6">
                  
                  <option value="1" >None</option>
                  
                  <option value="2" >Bracket 1: Exhibition</option>
                  
                  <option value="3" >Bracket 2: Core</option>
                  
                  <option value="4" >Bracket 3: Upgraded</option>
                  
                  <option value="5" >Bracket 4: Optimized</option>
                  
                  <option value="6" >Bracket 5: Competitive</option>
                  
              </select>
          </div>
      </div>
      <div class="actions">
          <button type="submit" class="button">Apply filters</button>
          <a href="?" class="button">Reset</a>
      </div>
  </form>
  
