    gap: 0.25rem;
    flex: 1 1 12rem;
    min-width: 10rem;
  }
  .filters label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
  }
  .filters input,
  .filters select {
    background: #16213e;
    color: #e0e0e0;
    border: 1px solid #333;
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
  }
  .filters select[multiple] {
    min-height: 5.5rem;
  }
  .filters .actions {
    margin-top: 0.75rem;
    justify-content: flex-start;
  }
  
  table thead th .sort {
    color: #9ca3af;
    text-decoration: none;
    white-space: nowrap;
  }
  table thead th .sort:hover {
    color: #c4b5fd;
  }
  table thead th .sort .arrow {
    margin-left: 0.25rem;
    color: #c4b5fd;
  }
  
  .count {
    color: #9ca3af;
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #333;
    text-align: center;
    font-size: 0.875rem;
    color: #6b7280;
  }
  
  @media (max-width: 720px) {
    body {
      padding: 1rem;
    }
    .header {
      flex-direction: column;
      align-items: flex-start;
    }
    table thead {
      display: none;
    }
    table,
    table tbody,
    table tr,
    table td {
      display: block;
      width: 100%;
    }
    table tbody tr {
      padding: 0.75rem 0;
      border-bottom: 1px solid #2a2a4a;
    }
    table tbody tr + tr td {
      border-top: none;
    }
    table tbody td {
      padding: 0.5rem 0.75rem;
    }
    table tbody td::before {
      content: attr(data-label);
      display: block;
      color: #9ca3af;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.15rem;
    }
  }
