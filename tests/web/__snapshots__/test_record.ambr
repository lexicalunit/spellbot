  a.button:active {
    color: #c4b5fd;
  }
  a.button:hover {
    color: #c4b5fd;
    text-decoration: none;
  }
  
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    justify-content: flex-end;
  }
  
  .filters {
    background: #1e1e3f;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }
  .filters .row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
  }
  .filters .field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1 1 12rem;
    min-width: 10rem;
  }
  .filters label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
  }
  .filters input,
  .filters select {
    background: #16213e;
    color: #e0e0e0;
