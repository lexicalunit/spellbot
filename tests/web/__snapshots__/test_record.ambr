    margin: 0 auto;
  }
  
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #333;
  }
  .header img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
  }
  .header .titles {
    flex: 1;
    min-width: 0;
  }
  .header h1 {
    font-size: 1.5rem;
    font-weight: 600;
    word-break: break-word;
  }
  .header .subtitle {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-top: 0.25rem;
  }
  
  .section {
    margin-bottom: 1.5rem;
  }
  .section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #c4b5fd;
    margin-bottom: 0.5rem;
  }
  
  .card {
    background: #252545;
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
  }
  
  .empty {
    color: #9ca3af;
    font-style: italic;
    padding: 0.5rem 0;
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
  }
  table th,
  table td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    vertical-align: top;
  }
  table thead th {
    color: #9ca3af;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #333;
    white-space: nowrap;
  }
  table tbody tr + tr td {
    border-top: 1px solid #2a2a4a;
  }
  table tbody tr:nth-child(even) td {
    background: #1a1a35;
  }
  table tbody td {
    color: #e0e0e0;
    font-size: 0.9rem;
  }
  
  .user-id {
    font-family: monospace;
    color: #9ca3af;
    font-size: 0.85rem;
  }
  
  .id-copy {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  
  .copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-left: 0.35rem;
    border-radius: 4px;
    background: #1e1e3f;
    border: 1px solid #333;
    color: #c4b5fd;
    font-size: 0.75rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
    vertical-align: middle;
  }
  .copy:hover {
    background: #2a2a55;
  }
  .copy.copied {
    color: #4ade80;
  }
  
  .players {
