    min-height: 5.5rem;
  }
  .filters .actions {
    margin-top: 0.75rem;
    justify-content: flex-start;
  }
  
  table thead th .sort {
    color: #9ca3af;
    text-decoration: none;
    white-space: nowrap;
  }
  table thead th .sort:hover {
    color: #c4b5fd;
  }
  table thead th .sort .arrow {
    margin-left: 0.25rem;
    color: #c4b5fd;
  }
  
  .count {
    color: #9ca3af;
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #333;
