                      "group": "grafana-postgresql-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  $__timeGroupAlias(created_at,1d),\n  (sum(case when format in (1, 12, 13, 14, 15, 16, 17) and bracket != 1 then 1 else 0 end) * 1.0) /\n   sum(case when format in (1, 12, 13, 14, 15, 16, 17) then 1 else 0 end) * 100.0\n   as \"Adoption Rate\"\nFROM games\nWHERE $__timeFilter(created_at)\n  AND started_at is not null\nGROUP BY 1\nORDER BY 1;",
