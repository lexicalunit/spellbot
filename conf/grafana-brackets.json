                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  $__timeGroup(created_at,1d) AS \"time\",\n  COUNT(id) AS \"Bracket 1: Exhibition\"\nFROM games\nWHERE $__timeFilter(created_at)\n  AND started_at is not null\n  AND bracket = 2\nGROUP BY 1\nORDER BY 1;",
