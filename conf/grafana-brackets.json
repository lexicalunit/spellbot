                        "rawSql": "SELECT\n  $__timeGroupAlias(created_at,1d),\n  COUNT(id) AS \"Bracket 5: Competitive\"\nFROM games\nWHERE $__timeFilter(created_at)\n  AND started_at is not null\n  AND bracket = 6\nGROUP BY 1\nORDER BY 1;",
