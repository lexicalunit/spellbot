{% extends "record_base.html.j2" %}
{% from "record_filters.html.j2" import sort_header, filter_form with context %}
{% from "motd_help.html.j2" import motd_placeholders with context %}
{% block title %}{{ t("web.records.channel_title", name=target_name or target_xid) }}{% endblock %}
{% block heading %}{{ t("web.records.channel_heading", name=target_name or t("web.common.unknown_channel") ) }}{% endblock %}
{% block subtitle %}
    <div class="subtitle">
        {% if guild_name %}<a href="/g/{{ guild_xid }}">{{ guild_name }}</a>{% endif %}
        <a href="https://discord.com/channels/{{ guild_xid }}/{{ target_xid }}"
           class="button">{{ t("web.common.jump_to_channel") | replace(" ", "&nbsp;") | safe }}</a>
    </div>
{% endblock %}
{% block content %}
    {%- if not is_logged_in %}
        <div class="section">
            <div class="card">
                <p class="login-prompt">
                    {{ t("web.records.mod_manage_channel") }}
                    <a href="{{ login_url }}" class="button">{{ t("web.common.login_with_discord") }}</a>
                </p>
            </div>
        </div>
    {%- endif %}
    {%- if is_moderator and channel %}
        <div class="section">
            <h2>{{ t("web.channel_settings.heading") }}</h2>
            <div class="card">
                <form method="post"
                      action="/g/{{ guild_xid }}/c/{{ target_xid }}/settings"
                      class="settings-form">
                    <div class="grid">
                        <div class="field">
                            <label for="ch-seats">{{ t("web.channel_settings.default_seats") }}</label>
                            <p class="hint">{{ channel_help['default_seats'] }}</p>
                            <select id="ch-seats" name="default_seats">
                                {% for n in seat_choices %}
                                    <option value="{{ n }}"
                                            {{ 'selected' if channel.default_seats == n else '' }}>{{ n }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="field">
                            <label for="ch-format">{{ t("web.channel_settings.default_format") }}</label>
                            <p class="hint">{{ channel_help['default_format'] }}</p>
                            <select id="ch-format" name="default_format">
                                {% for choice in format_choices %}
                                    <option value="{{ choice.value }}"
                                            {{ 'selected' if channel.default_format.value == choice.value else '' }}>{{ choice.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="field">
                            <label for="ch-bracket">{{ t("web.channel_settings.default_bracket") }}</label>
                            <p class="hint">{{ channel_help['default_bracket'] }}</p>
                            <select id="ch-bracket" name="default_bracket">
                                {% for choice in bracket_choices %}
                                    <option value="{{ choice.value }}"
                                            {{ 'selected' if channel.default_bracket.value == choice.value else '' }}>{{ choice.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="field">
                            <label for="ch-service">{{ t("web.channel_settings.default_service") }}</label>
                            <p class="hint">{{ channel_help['default_service'] }}</p>
                            <select id="ch-service" name="default_service">
                                {% for choice in service_choices %}
                                    <option value="{{ choice.value }}"
                                            {{ 'selected' if channel.default_service.value == choice.value else '' }}>{{ choice.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="field">
                            <label for="ch-motd">{{ t("web.channel_settings.motd") }}</label>
                            <p class="hint">{{ channel_help['motd'] }}</p>
                            <input type="text"
                                   id="ch-motd"
                                   name="motd"
                                   maxlength="255"
                                   value="{{ channel.motd | default('', true) }}">
                            {{ motd_placeholders() }}
                        </div>
                        <div class="field">
                            <label for="ch-extra">{{ t("web.channel_settings.extra") }}</label>
                            <p class="hint">{{ channel_help['extra'] }}</p>
                            <input type="text"
                                   id="ch-extra"
                                   name="extra"
                                   maxlength="255"
                                   value="{{ channel.extra | default('', true) }}">
                        </div>
                        <div class="field">
                            <label for="ch-vc-category">{{ t("web.channel_settings.voice_category") }}</label>
                            <p class="hint">{{ channel_help['voice_category'] }}</p>
                            <input type="text"
                                   id="ch-vc-category"
                                   name="voice_category"
                                   maxlength="50"
                                   value="{{ channel.voice_category | default('', true) }}">
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-auto-verify"
                                       name="auto_verify"
                                       value="true"
                                       {{ 'checked' if channel.auto_verify else '' }}>
                                <label for="ch-auto-verify">{{ t("web.channel_settings.auto_verify") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['auto_verify'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-verified-only"
                                       name="verified_only"
                                       value="true"
                                       {{ 'checked' if channel.verified_only else '' }}>
                                <label for="ch-verified-only">{{ t("web.channel_settings.verified_only") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['verified_only'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-unverified-only"
                                       name="unverified_only"
                                       value="true"
                                       {{ 'checked' if channel.unverified_only else '' }}>
                                <label for="ch-unverified-only">{{ t("web.channel_settings.unverified_only") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['unverified_only'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-voice-invite"
                                       name="voice_invite"
                                       value="true"
                                       {{ 'checked' if channel.voice_invite else '' }}>
                                <label for="ch-voice-invite">{{ t("web.channel_settings.voice_invite") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['voice_invite'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-delete-expired"
                                       name="delete_expired"
                                       value="true"
                                       {{ 'checked' if channel.delete_expired else '' }}>
                                <label for="ch-delete-expired">{{ t("web.channel_settings.delete_expired") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['delete_expired'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-blind-games"
                                       name="blind_games"
                                       value="true"
                                       {{ 'checked' if channel.blind_games else '' }}>
                                <label for="ch-blind-games">{{ t("web.channel_settings.blind_games") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['blind_games'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="ch-to-mode"
                                       name="to_mode"
                                       value="true"
                                       {{ 'checked' if channel.to_mode else '' }}>
                                <label for="ch-to-mode">{{ t("web.channel_settings.to_mode") }}</label>
                            </div>
                            <p class="hint">{{ channel_help['to_mode'] }}</p>
                        </div>
                    </div>
                    <div class="actions">
                        <button type="submit" class="button">{{ t("web.channel_settings.save") }}</button>
                        <a href="/g/{{ guild_xid }}/c/{{ target_xid }}/audit" class="button">{{ t("web.common.view_change_history") }}</a>
                    </div>
                </form>
            </div>
            <div class="card">
                <p class="hint">{{ t("web.channel_settings.forget_hint") }}</p>
                <form method="post"
                      action="/g/{{ guild_xid }}/c/{{ target_xid }}/forget"
                      class="settings-form"
                      onsubmit='return confirm({{ t("web.channel_settings.forget_confirm") | tojson }});'>
                    <div class="actions">
                        <button type="submit" class="button button-danger">{{ t("web.channel_settings.forget") }}</button>
                    </div>
                </form>
            </div>
        </div>
    {%- endif %}
    <div class="section">
        <h2>{{ t("web.records.games") }} <span class="count">({{ t("web.records.matching", count=total) }})</span></h2>
        {{ filter_form(false, format_choices, bracket_choices, filters) }}
        <div class="card">
            {% if records %}
                <table>
                    <thead>
                        <tr>
                            <th>{{ sort_header('id', t("web.field.game") , sort_by, sort_dir, filters) }}</th>
                            <th>{{ sort_header('updated_at', t("web.field.time") , sort_by, sort_dir, filters) }}</th>
                            <th>{{ sort_header('format', t("web.field.format") , sort_by, sort_dir, filters) }}</th>
                            <th>{{ sort_header('seats', t("web.field.seats") , sort_by, sort_dir, filters) }}</th>
                            <th>{{ sort_header('bracket', t("web.field.bracket") , sort_by, sort_dir, filters) }}</th>
                            <th>{{ t("web.field.locale") }}</th>
                            <th>{{ t("web.field.user_name") }}</th>
                            <th>{{ t("web.field.user_id") }}</th>
                            <th>{{ t("web.field.jump") }}</th>
                        </tr>
                    </thead>
                    <tbody id="rows">
                        {% for record in records %}
                            <tr>
                                <td data-label="{{ t('web.field.game') }}"><a href="/game/{{ record.id }}">SB#{{ record.id }}</a></td>
                                {% if tz_offset and tz_name %}
                                    <td data-label="{{ t('web.field.time') }}">{{ record.updated_at | humanize(tz_offset, tz_name) }}</td>
                                {% else %}
                                    <td data-label="{{ t('web.field.time') }}" class="timestamp">{{ record.updated_at }}</td>
                                {% endif %}
                                <td data-label="{{ t('web.field.format') }}">{{ record.format }}</td>
                                <td data-label="{{ t('web.field.seats') }}">{{ record.seats }}</td>
                                <td data-label="{{ t('web.field.bracket') }}">{{ record.bracket }}</td>
                                <td data-label="{{ t('web.field.locale') }}">{{ record.locale }}</td>
                                <td data-label="{{ t('web.field.user_name') }}">
                                    <a href="/u/{{ record.user_xid }}">{{ record.user_name | default(t("web.common.unknown_user") , true) }}</a>
                                </td>
                                <td data-label="{{ t('web.field.user_id') }}">
                                    <span class="id-copy">
                                        <span class="user-id">{{ record.user_xid }}</span>
                                        <button type="button"
                                                class="copy"
                                                data-copy="{{ record.user_xid }}"
                                                title="{{ t('web.common.copy_user_id') }}">⎘</button>
                                    </span>
                                </td>
                                <td data-label="{{ t('web.field.jump') }}"><a href="https://discord.com/channels/{{ record.guild }}/{{ record.channel }}/{{ record.message }}"
   class="button">{{ t("web.common.jump_to_game") | replace(" ", "&nbsp;") | safe }}</a></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="empty">{{ t("web.records.none_channel") }}</div>
            {% endif %}
        </div>
    </div>
{% endblock %}
