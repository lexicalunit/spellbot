{% extends "record_base.html.j2" %}
{% from "record_filters.html.j2" import sort_header, filter_form %}
{% block title %}Channel Records — #{{ target_name or target_xid }}{% endblock %}
{% block heading %}Channel Records: #{{ target_name or 'Unknown Channel' }}{% endblock %}
{% block subtitle %}
<div class="subtitle">
    {% if guild_name %}<a href="/g/{{ guild_xid }}">{{ guild_name }}</a> &middot;{% endif %}
    <a href="https://discord.com/channels/{{ guild_xid }}/{{ target_xid }}">Open channel</a>
</div>
{% endblock %}
{% block content %}
{%- if not is_logged_in %}
<div class="section">
    <div class="card">
        <p class="login-prompt">
            Moderators can manage this channel's settings here.
            <a href="{{ login_url }}" class="button">Log in with Discord</a>
        </p>
    </div>
</div>
{%- endif %}
{%- if is_moderator and channel %}
<div class="section">
    <h2>Channel Settings</h2>
    <div class="card">
        <form method="post" action="/g/{{ guild_xid }}/c/{{ target_xid }}/settings" class="settings-form">
            <div class="grid">
                <div class="field">
                    <label for="ch-seats">Default seats</label>
                    <p class="hint">{{ channel_help['default_seats'] }}</p>
                    <select id="ch-seats" name="default_seats">
                        {% for n in seat_choices %}
                        <option value="{{ n }}" {{ 'selected' if channel.default_seats == n else '' }}>{{ n }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="ch-format">Default format</label>
                    <p class="hint">{{ channel_help['default_format'] }}</p>
                    <select id="ch-format" name="default_format">
                        {% for choice in format_choices %}
                        <option value="{{ choice.value }}" {{ 'selected' if channel.default_format.value == choice.value else '' }}>{{ choice.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="ch-bracket">Default bracket</label>
                    <p class="hint">{{ channel_help['default_bracket'] }}</p>
                    <select id="ch-bracket" name="default_bracket">
                        {% for choice in bracket_choices %}
                        <option value="{{ choice.value }}" {{ 'selected' if channel.default_bracket.value == choice.value else '' }}>{{ choice.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="ch-service">Default service</label>
                    <p class="hint">{{ channel_help['default_service'] }}</p>
                    <select id="ch-service" name="default_service">
                        {% for choice in service_choices %}
                        <option value="{{ choice.value }}" {{ 'selected' if channel.default_service.value == choice.value else '' }}>{{ choice.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="ch-motd">Message of the day</label>
                    <p class="hint">{{ channel_help['motd'] }}</p>
                    <input type="text" id="ch-motd" name="motd" maxlength="255"
                           value="{{ channel.motd | default('', true) }}">
                </div>
                <div class="field">
                    <label for="ch-extra">Extra message</label>
                    <p class="hint">{{ channel_help['extra'] }}</p>
                    <input type="text" id="ch-extra" name="extra" maxlength="255"
                           value="{{ channel.extra | default('', true) }}">
                </div>
                <div class="field">
                    <label for="ch-vc-category">Voice category</label>
                    <p class="hint">{{ channel_help['voice_category'] }}</p>
                    <input type="text" id="ch-vc-category" name="voice_category" maxlength="50"
                           value="{{ channel.voice_category | default('', true) }}">
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-auto-verify" name="auto_verify" value="true"
                               {{ 'checked' if channel.auto_verify else '' }}>
                        <label for="ch-auto-verify">Auto-verify users</label>
                    </div>
                    <p class="hint">{{ channel_help['auto_verify'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-verified-only" name="verified_only" value="true"
                               {{ 'checked' if channel.verified_only else '' }}>
                        <label for="ch-verified-only">Verified users only</label>
                    </div>
                    <p class="hint">{{ channel_help['verified_only'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-unverified-only" name="unverified_only" value="true"
                               {{ 'checked' if channel.unverified_only else '' }}>
                        <label for="ch-unverified-only">Unverified users only</label>
                    </div>
                    <p class="hint">{{ channel_help['unverified_only'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-voice-invite" name="voice_invite" value="true"
                               {{ 'checked' if channel.voice_invite else '' }}>
                        <label for="ch-voice-invite">Create voice invites</label>
                    </div>
                    <p class="hint">{{ channel_help['voice_invite'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-delete-expired" name="delete_expired" value="true"
                               {{ 'checked' if channel.delete_expired else '' }}>
                        <label for="ch-delete-expired">Delete expired games</label>
                    </div>
                    <p class="hint">{{ channel_help['delete_expired'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-blind-games" name="blind_games" value="true"
                               {{ 'checked' if channel.blind_games else '' }}>
                        <label for="ch-blind-games">Blind games</label>
                    </div>
                    <p class="hint">{{ channel_help['blind_games'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="ch-to-mode" name="to_mode" value="true"
                               {{ 'checked' if channel.to_mode else '' }}>
                        <label for="ch-to-mode">Tournament organizer mode</label>
                    </div>
                    <p class="hint">{{ channel_help['to_mode'] }}</p>
                </div>
            </div>
            <div class="actions">
                <button type="submit" class="button">Save channel settings</button>
            </div>
        </form>
    </div>
</div>
{%- endif %}
<div class="section">
    <h2>Games <span class="count">({{ total }} matching)</span></h2>
    {{ filter_form(false, format_choices, bracket_choices, filters) }}
    <div class="card">
        {% if records %}
        <table>
            <thead>
                <tr>
                    <th>{{ sort_header('id', 'Game', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('updated_at', 'Time', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('format', 'Format', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('seats', 'Seats', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('bracket', 'Bracket', sort_by, sort_dir, filters) }}</th>
                    <th>Locale</th>
                    <th>Link</th>
                    <th>User Name</th>
                    <th>User ID</th>
                    <th>Jump</th>
                </tr>
            </thead>
            <tbody id="rows">
                {% for record in records %}
                <tr>
                    <td data-label="Game"><a href="/game/{{ record.id }}">SB#{{ record.id }}</a></td>
                    {% if tz_offset and tz_name %}
                    <td data-label="Time">{{ record.updated_at | humanize(tz_offset, tz_name) }}</td>
                    {% else %}
                    <td data-label="Time" class="timestamp">{{ record.updated_at }}</td>
                    {% endif %}
                    <td data-label="Format">{{ record.format }}</td>
                    <td data-label="Seats">{{ record.seats }}</td>
                    <td data-label="Bracket">{{ record.bracket }}</td>
                    <td data-label="Locale">{{ record.locale }}</td>
                    <td data-label="Link">
                        {% if record.link %}<a href="{{ record.link }}">Open in {{ record.service }}</a>{% else %}&mdash;{% endif %}
                    </td>
                    <td data-label="User Name">
                        <a href="/u/{{ record.user_xid }}">{{ record.user_name | default('Unknown User', true) }}</a>
                    </td>
                    <td data-label="User ID">
                        <span class="id-copy">
                            <span class="user-id">{{ record.user_xid }}</span>
                            <button type="button" class="copy" data-copy="{{ record.user_xid }}" title="Copy User ID">⎘</button>
                        </span>
                    </td>
                    <td data-label="Jump"><a href="https://discord.com/channels/{{ record.guild }}/{{ record.channel }}/{{ record.message }}" class="button">Jump&nbsp;to&nbsp;game</a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty">No games found for this channel.</div>
        {% endif %}
    </div>
</div>
{% endblock %}
