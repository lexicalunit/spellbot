{% extends "record_base.html.j2" %}
{% from "record_filters.html.j2" import sort_header, filter_form %}
{% block title %}Channel Records — #{{ target_name or target_xid }}{% endblock %}
{% block heading %}Channel Records: #{{ target_name or 'Unknown Channel' }}{% endblock %}
{% block subtitle %}
<div class="subtitle">
    {% if guild_name %}<a href="https://discord.com/channels/{{ guild_xid }}">{{ guild_name }}</a> &middot;{% endif %}
    <a href="https://discord.com/channels/{{ guild_xid }}/{{ target_xid }}">Open channel</a>
</div>
{% endblock %}
{% block content %}
<div class="section">
    <h2>Games <span class="count">({{ total }} matching)</span></h2>
    {{ filter_form(false, format_choices, bracket_choices, filters) }}
    <div class="card">
        {% if records %}
        <table>
            <thead>
                <tr>
                    <th>{{ sort_header('id', 'Game', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('updated_at', 'Time', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('format', 'Format', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('seats', 'Seats', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('bracket', 'Bracket', sort_by, sort_dir, filters) }}</th>
                    <th>Locale</th>
                    <th>Link</th>
                    <th>User Name</th>
                    <th>User ID</th>
                    <th>Jump</th>
                </tr>
            </thead>
            <tbody id="rows">
                {% for record in records %}
                <tr>
                    <td data-label="Game"><a href="/game/{{ record.id }}">SB#{{ record.id }}</a></td>
                    {% if tz_offset and tz_name %}
                    <td data-label="Time">{{ record.updated_at | humanize(tz_offset, tz_name) }}</td>
                    {% else %}
                    <td data-label="Time" class="timestamp">{{ record.updated_at }}</td>
                    {% endif %}
                    <td data-label="Format">{{ record.format }}</td>
                    <td data-label="Seats">{{ record.seats }}</td>
                    <td data-label="Bracket">{{ record.bracket }}</td>
                    <td data-label="Locale">{{ record.locale }}</td>
                    <td data-label="Link">
                        {% if record.link %}<a href="{{ record.link }}">Open in {{ record.service }}</a>{% else %}&mdash;{% endif %}
                    </td>
                    <td data-label="User Name">
                        <a href="/u/{{ record.user_xid }}">{{ record.user_name | default('Unknown User', true) }}</a>
                    </td>
                    <td data-label="User ID">
                        <span class="id-copy">
                            <span class="user-id">{{ record.user_xid }}</span>
                            <button type="button" class="copy" data-copy="{{ record.user_xid }}" title="Copy User ID">⎘</button>
                        </span>
                    </td>
                    <td data-label="Jump"><a href="https://discord.com/channels/{{ record.guild }}/{{ record.channel }}/{{ record.message }}" class="button">Jump&nbsp;to&nbsp;game</a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty">No games found for this channel.</div>
        {% endif %}
    </div>
</div>
{% endblock %}
