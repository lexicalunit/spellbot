<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>SpellBot Admin Dashboard</title>
    <meta name="theme-color" content="#5A3EFD">
    <link rel="icon" type="image/x-icon" href="https://spellbot.io/favicon.ico">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #e0e0e0; min-height: 100vh; padding: 2rem;
        }
        a, a:visited, a:active { color: rgba(246, 173, 75); text-decoration: none; }
        a:hover { filter: brightness(150%); }
        .container { max-width: 1280px; margin: 0 auto; }
        .header {
            display: flex; align-items: center; gap: 1rem;
            margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #333;
        }
        .header img { width: 56px; height: 56px; border-radius: 50%; }
        .header h1 { font-size: 1.5rem; font-weight: 600; flex: 1; }
        .header .user { font-size: 0.85rem; color: #9ca3af; }
        .header form { display: inline; margin-left: 0.5rem; }
        .header button.logout {
            background: #1e1e3f; color: #c4b5fd; border: 1px solid #333;
            padding: 0.35rem 0.75rem; border-radius: 6px; cursor: pointer;
            font-size: 0.8rem;
        }
        .header button.logout:hover { background: #2a2a50; }
        .sticky-controls {
            position: sticky; top: 0; background: #1a1a2e; z-index: 100;
            display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem;
            padding: 0.75rem 0; margin: -0.5rem 0 1rem 0;
        }
        .toggle-group { display: inline-flex; background: #1e1e3f; border-radius: 6px; overflow: hidden; }
        .toggle-btn {
            padding: 0.35rem 0.75rem; font-size: 0.75rem; border: none; cursor: pointer;
            background: transparent; color: #9ca3af; transition: all 0.15s;
        }
        .toggle-btn.active { background: #818cf8; color: #fff; }
        .guild-filter { display: inline-flex; align-items: center; gap: 0.5rem; }
        .guild-filter select, .guild-filter input {
            background: #1e1e3f; color: #e0e0e0; border: 1px solid #333;
            padding: 0.35rem 0.5rem; border-radius: 6px; font-size: 0.8rem;
        }
        .guild-filter select { min-width: 220px; }
        .bucket-indicator {
            font-size: 0.75rem; color: #9ca3af;
            background: #1e1e3f; border: 1px solid #333;
            padding: 0.3rem 0.6rem; border-radius: 6px;
        }
        .bucket-indicator span { color: #c4b5fd; font-weight: 600; text-transform: capitalize; }
        .summary {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 1rem; margin-bottom: 1.5rem;
        }
        .stat {
            background: #252545; border-radius: 12px; padding: 1.25rem;
            text-align: center; position: relative; min-height: 80px;
        }
        .stat-value { font-size: 1.75rem; font-weight: 700; color: #818cf8; }
        .stat-value .stat-unit { font-size: 0.8rem; font-weight: 500; color: #9ca3af; margin-left: 0.25rem; }
        .stat-label { font-size: 0.8rem; color: #9ca3af; margin-top: 0.25rem; }
        .stat-value.bracket-1 { color: #22c55e; }
        .stat-value.bracket-2 { color: #facc15; }
        .stat-value.bracket-3 { color: #3b82f6; }
        .stat-value.bracket-4 { color: #f97316; }
        .stat-value.bracket-5 { color: #ef4444; }
        .section { margin-bottom: 1.5rem; }
        .section h2 { font-size: 1.1rem; font-weight: 600; color: #c4b5fd; margin-bottom: 0.5rem; }
        .chart-box {
            background: #252545; border-radius: 12px; padding: 1.25rem;
            position: relative; width: 100%; min-width: 0; min-height: 360px;
        }
        .chart-box canvas { display: block; width: 100% !important; height: 100% !important; }
        .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
        .row.row-three { grid-template-columns: 1fr 1fr 1fr; }
        @media (max-width: 900px) { .row, .row.row-three { grid-template-columns: 1fr; } }
        .footer {
            margin-top: 2rem; padding-top: 1rem;
            border-top: 1px solid #333; text-align: center;
            font-size: 0.875rem; color: #6b7280;
        }
        .section-loading {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            height: 100%; min-height: 320px; gap: 0.75rem;
        }
        .section-spinner {
            width: 32px; height: 32px;
            border: 3px solid rgba(129,140,248,0.2);
            border-top-color: #818cf8;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        .section-loading-text { color: #9ca3af; font-size: 0.8rem; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .section-error { color: #fca5a5; text-align: center; padding: 1rem; }
        .no-data { text-align: center; padding: 2rem; background: #252545; border-radius: 12px; color: #9ca3af; }
        .table-box {
            background: #252545; border-radius: 12px; padding: 1.25rem;
            position: relative; width: 100%; min-width: 0; min-height: 360px;
            max-height: 480px; overflow-y: auto;
            scrollbar-width: thin; scrollbar-color: #4b4b6b transparent;
        }
        .table-box::-webkit-scrollbar { width: 8px; }
        .table-box::-webkit-scrollbar-track { background: transparent; }
        .table-box::-webkit-scrollbar-thumb {
            background: #4b4b6b; border-radius: 4px;
            border: 2px solid #252545; background-clip: padding-box;
        }
        .table-box::-webkit-scrollbar-thumb:hover { background: #6b6b8b; background-clip: padding-box; }
        .lang-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
        .lang-table th, .lang-table td {
            text-align: left; padding: 0.4rem 0.5rem; border-bottom: 1px solid #333;
        }
        .lang-table th { color: #9ca3af; font-weight: 600; position: sticky; top: 0; background: #252545; }
        .lang-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
        .lang-table td.pct { text-align: right; color: #9ca3af; font-variant-numeric: tabular-nums; }
        .lang-table tr:last-child td { border-bottom: none; }
        .player-xid { color: #9ca3af; font-size: 0.75rem; font-variant-numeric: tabular-nums; }
        .word-cloud {
            display: flex; flex-wrap: wrap; gap: 0.4rem 0.6rem;
            justify-content: center; align-items: center;
            padding: 1.25rem; background: linear-gradient(135deg, #1e1e3f 0%, #252545 100%);
            border-radius: 12px; min-height: 180px;
        }
        .cloud-word {
            cursor: default; transition: transform 0.2s, filter 0.2s;
            white-space: nowrap; padding: 0.15rem 0.4rem;
            border-radius: 4px; font-weight: 500;
            text-shadow: 0 1px 2px rgba(0,0,0,0.3);
        }
        .cloud-word:hover { transform: scale(1.15) rotate(0deg) !important; filter: brightness(1.3); z-index: 10; position: relative; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <a href="https://spellbot.io/">
                <img alt="SpellBot" src="https://spellbot.io/assets/img/avatar-icon.png">
            </a>
            <h1>SpellBot Admin Dashboard</h1>
            <span class="user">Signed in as <strong>{{ admin_name }}</strong></span>
            <form action="/admin/logout" method="post">
                <button class="logout" type="submit">Sign out</button>
            </form>
        </div>

        <div class="sticky-controls">
            <div class="toggle-group" id="periodToggle">
                <button class="toggle-btn" data-period="7d">7d</button>
                <button class="toggle-btn active" data-period="30d">30d</button>
                <button class="toggle-btn" data-period="90d">90d</button>
                <button class="toggle-btn" data-period="180d">6mo</button>
                <button class="toggle-btn" data-period="365d">1y</button>
                <button class="toggle-btn" data-period="730d">2y</button>
                <button class="toggle-btn" data-period="all">All</button>
            </div>
            <div class="guild-filter">
                <div class="toggle-group" id="guildModeToggle">
                    <button class="toggle-btn active" data-mode="all">All</button>
                    <button class="toggle-btn" data-mode="include">Only</button>
                    <button class="toggle-btn" data-mode="exclude">Except</button>
                </div>
                <select id="guildSelect" disabled>
                    <option value="">All servers</option>
                </select>
            </div>
            <div class="bucket-indicator">Bucket: <span id="bucketLabel">—</span></div>
        </div>

        <div class="summary">
            <div class="stat"><div id="statTotalGames" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Total Games</div></div>
            <div class="stat"><div id="statTotalPlayers" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Total Players</div></div>
            <div class="stat"><div id="statTotalServers" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Total Servers</div></div>
        </div>

        <div class="summary">
            <div class="stat"><div id="statGames" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Games</div></div>
            <div class="stat"><div id="statPlayers" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Players</div></div>
            <div class="stat"><div id="statServers" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Active Servers</div></div>
            <div class="stat"><div id="statWau" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Avg WAU</div></div>
            <div class="stat"><div id="statMau" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">Avg MAU</div></div>
            <div class="stat"><div id="statDauMau" class="stat-value"><div class="section-spinner"></div></div><div class="stat-label">DAU:MAU %</div></div>
        </div>

        <div class="section"><h2>User Activity</h2><div id="usersActivitySection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        <div class="section"><h2>Games (Started vs Expired)</h2><div id="gamesSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        <div class="section"><h2>Casual vs cEDH (% of bucket)</h2><div id="casualVsCedhSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        <div class="section"><h2>Server Popularity (Top 20, % of bucket)</h2><div id="serverPopularitySection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        <div class="section"><h2>Service Popularity (% of bucket)</h2><div id="servicePopularitySection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>

        <div class="summary">
            <div class="stat"><div id="statBracket1" class="stat-value bracket-1"><div class="section-spinner"></div></div><div class="stat-label">Bracket 1: Exhibition</div></div>
            <div class="stat"><div id="statBracket2" class="stat-value bracket-2"><div class="section-spinner"></div></div><div class="stat-label">Bracket 2: Core</div></div>
            <div class="stat"><div id="statBracket3" class="stat-value bracket-3"><div class="section-spinner"></div></div><div class="stat-label">Bracket 3: Upgraded</div></div>
            <div class="stat"><div id="statBracket4" class="stat-value bracket-4"><div class="section-spinner"></div></div><div class="stat-label">Bracket 4: Optimized</div></div>
            <div class="stat"><div id="statBracket5" class="stat-value bracket-5"><div class="section-spinner"></div></div><div class="stat-label">Bracket 5: Competitive</div></div>
        </div>
        <div class="section"><h2>Bracket Adoption Rate</h2><div id="bracketAdoptionSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>

        <div class="row">
            <div class="section"><h2>Popular Hours of Day (Local Time)</h2><div id="hourOfDaySection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Popular Days of Week (UTC)</h2><div id="dayOfWeekSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        </div>

        <div class="section"><h2>Average Wait Time</h2><div id="avgWaitTimeSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>

        <div class="section"><h2 id="gamesPerPlayerTitle">Games per Player</h2><div id="gamesPerPlayerSection" class="chart-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>

        <div class="row">
            <div class="section"><h2>Popular Game Formats</h2><div id="popularFormatsSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Popular Seat Counts</h2><div id="popularSeatsSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        </div>

        <div class="row">
            <div class="section"><h2>Most Active Players</h2><div id="topPlayersSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Most Blocked Players (All Time)</h2><div id="topBlockedSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        </div>

        <div class="row row-three">
            <div class="section"><h2>User Languages</h2><div id="userLanguagesSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Game Languages</h2><div id="gameLanguagesSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Guild Languages</h2><div id="guildLanguagesSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        </div>

        <div class="section"><h2>Most Active Server per Language</h2><div id="topGuildPerGameLanguageSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>

        <div class="row">
            <div class="section"><h2>Top Game Rules</h2><div id="topRulesSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
            <div class="section"><h2>Rules Word Cloud</h2><div id="rulesCloudSection" class="table-box"><div class="section-loading"><div class="section-spinner"></div><div class="section-loading-text">Loading...</div></div></div></div>
        </div>

        <div class="footer"><p>SpellBot Admin Dashboard</p></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3"></script>
    <script>window.CHART_AVAILABLE = typeof Chart !== "undefined";</script>
    <script src="/dashboard.js"></script>
</body>
</html>
