<!DOCTYPE html>
<html lang="{{ lang }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport"
              content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>{{ t("web.notify.title", name=guild.guild_name or t("web.common.spellbot_server") ) }}</title>
        <meta name="description" content="{{ t('web.notify.meta_description') }}">
        <meta name="theme-color" content="#1a202c">
        <link rel="icon" type="image/x-icon" href="https://spellbot.io/favicon.ico">
        <style>
        {% include "base.css" %}
        {% include "queues.css" %}
        {% include "guild_notify.css" %}
        </style>
    </head>
    <body>
        <div class="container">
            <header class="page-header">
                <a href="/queues">
                    <img class="logo"
                         alt="SpellBot"
                         src="https://spellbot.io/assets/img/avatar-icon.png">
                </a>
                <h1>{{ t("web.notify.heading") }}</h1>
                <nav class="page-header__links" aria-label="Site">
                    <a class="page-header__user" href="/queues">{{ t("web.nav.active_queues") }}</a>
                    <a class="page-header__user" href="/g/{{ guild.guild_xid }}">{{ t("web.nav.server_details") }}</a>
                    <a class="page-header__user" href="/u/{{ viewer.xid }}">{{ t("web.nav.my_records") }}</a>
                </nav>
            </header>
            <section class="notify">
                <div class="notify__guild">
                    <img class="notify__guild-logo"
                         src="{{ guild.logo }}"
                         alt="{{ guild.guild_name }}"
                         onerror="this.onerror=null;this.src='{{ default_logo }}';"
                         loading="lazy">
                    <div class="notify__guild-titles">
                        <h2 class="notify__guild-name">{{ guild.guild_name or t("web.common.spellbot_server") }}</h2>
                        <p class="notify__guild-sub">{{ t("web.notify.guild_sub") }}</p>
                    </div>
                </div>
                <form method="post"
                      action="/queues/g/{{ guild.guild_xid }}/notify"
                      class="notify__form">
                    <div class="notify__off">
                        <label class="notify__off-option">
                            <input type="checkbox"
                                   id="notify-off"
                                   name="off"
                                   value="1"
                                   {% if notifications_off %}checked{% endif %}>
                            <span>{{ t("web.notify.off_label") }}</span>
                        </label>
                    </div>
                    <fieldset class="notify__fieldset">
                        <legend class="notify__legend">{{ t("web.notify.formats") }}</legend>
                        <p class="notify__hint">{{ t("web.notify.formats_hint") }}</p>
                        <div class="notify__options">
                            {% for c in format_choices %}
                                <label class="notify__option">
                                    <input type="checkbox"
                                           name="formats"
                                           value="{{ c.value }}"
                                           {% if c.value in selected_formats %}checked{% endif %}>
                                    <span>{{ c.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </fieldset>
                    <fieldset class="notify__fieldset">
                        <legend class="notify__legend">{{ t("web.notify.brackets") }}</legend>
                        <p class="notify__hint">{{ t("web.notify.brackets_hint") }}</p>
                        <div class="notify__options">
                            {% for c in bracket_choices %}
                                <label class="notify__option">
                                    <input type="checkbox"
                                           name="brackets"
                                           value="{{ c.value }}"
                                           {% if c.value in selected_brackets %}checked{% endif %}>
                                    <span>{{ c.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </fieldset>
                    {% if channel_choices|length > 1 %}
                        <fieldset class="notify__fieldset">
                            <legend class="notify__legend">{{ t("web.notify.channels") }}</legend>
                            <p class="notify__hint">{{ t("web.notify.channels_hint") }}</p>
                            <div class="notify__options">
                                {% for c in channel_choices %}
                                    <label class="notify__option">
                                        <input type="checkbox"
                                               name="channels"
                                               value="{{ c.value }}"
                                               {% if c.value in selected_channels %}checked{% endif %}>
                                        <span>#{{ c.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </fieldset>
                    {% endif %}
                    <fieldset class="notify__fieldset notify__hours">
                        <legend class="notify__legend">{{ t("web.notify.active_hours") }}</legend>
                        <p class="notify__hint">{{ t("web.notify.active_hours_hint", hours=active_hours_max_length) }}</p>
                        <label class="notify__hours-toggle">
                            <input type="checkbox"
                                   id="active-hours-enabled"
                                   name="active_hours_enabled"
                                   value="1"
                                   {% if active_hours %}checked{% endif %}>
                            <span>{{ t("web.notify.limit_window") }}</span>
                        </label>
                        <div class="notify__hours-panel"
                             data-default-start="17"
                             data-default-end="22">
                            <div class="notify__hours-readout" id="active-hours-readout"></div>
                            <div class="notify__hours-track" id="active-hours-track">
                                <div class="notify__hours-band" id="active-hours-band-a"></div>
                                <div class="notify__hours-band" id="active-hours-band-b"></div>
                                <div class="notify__hours-ticks" aria-hidden="true">
                                    {% for h in range(24) %}
                                        <span class="notify__hours-tick"
                                              style="left: calc((100% - 18px) * {{ h }} / 23 + 9px)"></span>
                                    {% endfor %}
                                </div>
                                <input type="range"
                                       id="active-hours-start"
                                       name="active_hours_start"
                                       min="0"
                                       max="23"
                                       step="1"
                                       value="{{ active_hours.start if active_hours else 17 }}">
                                <input type="range"
                                       id="active-hours-end"
                                       name="active_hours_end"
                                       min="0"
                                       max="23"
                                       step="1"
                                       value="{{ active_hours.end if active_hours else 22 }}">
                            </div>
                            <div class="notify__hours-axis" aria-hidden="true">
                                {% for h in [0, 6, 12, 18, 23] %}<span style="left: calc((100% - 18px) * {{ h }} / 23 + 9px);">{{ h }}</span>{% endfor %}
                            </div>
                            <p class="notify__hours-tz" id="active-hours-tz-label"></p>
                            <p class="notify__hours-error" id="active-hours-error" hidden></p>
                            <input type="hidden"
                                   id="active-hours-tz"
                                   name="active_hours_tz"
                                   value="{{ active_hours.tz if active_hours else '' }}">
                        </div>
                    </fieldset>
                    <div class="notify__actions">
                        <button type="submit" class="notify__save">{{ t("web.notify.save") }}</button>
                    </div>
                </form>
            </section>
            <footer class="page-footer">
                <p>{{ t("web.common.powered_by", link='<a href="https://spellbot.io/">SpellBot</a>') | safe }}</p>
            </footer>
        </div>
        <div id="notify-toast"
             class="notify__toast"
             role="status"
             aria-live="polite"
             hidden></div>
        <script>
        (function () {
            var form = document.querySelector(".notify__form");
            var toast = document.getElementById("notify-toast");
            if (!form || !toast) return;
            var I18N = {
                unit_hour: {{ t("web.notify.unit_hour") | tojson }},
                unit_hours: {{ t("web.notify.unit_hours") | tojson }},
                pick_different: {{ t("web.notify.js_pick_different") | tojson }},
                must_differ: {{ t("web.notify.js_must_differ") | tojson }},
                range_max: {{ t("web.notify.js_range_max", max=active_hours_max_length) | tojson }},
                times_in: {{ t("web.notify.js_times_in") | tojson }},
                times_local: {{ t("web.notify.js_times_local") | tojson }},
            };
            var successMessage = {{ t("web.notify.js_saved") | tojson }};
            var offMessage = {{ t("web.notify.js_off") | tojson }};
            var errorMessage = {{ t("web.notify.js_error") | tojson }};
            var hideTimer = null;
            var offCb = document.getElementById("notify-off");
            var fieldsets = form.querySelectorAll(".notify__fieldset");
            var saveBtn = form.querySelector(".notify__save");
            var ACTIVE_HOURS_MAX = {{ active_hours_max_length }};
            var hoursEnabledCb = document.getElementById("active-hours-enabled");
            var startSlider = document.getElementById("active-hours-start");
            var endSlider = document.getElementById("active-hours-end");
            var tzInput = document.getElementById("active-hours-tz");
            var tzLabel = document.getElementById("active-hours-tz-label");
            var readout = document.getElementById("active-hours-readout");
            var bandA = document.getElementById("active-hours-band-a");
            var bandB = document.getElementById("active-hours-band-b");
            var hoursError = document.getElementById("active-hours-error");
            var hoursPanel = document.querySelector(".notify__hours-panel");
            var hoursInvalid = false;
            function applyOffState() {
                if (!offCb) return;
                var isOff = offCb.checked;
                fieldsets.forEach(function (fs) { fs.disabled = isOff; });
                form.classList.toggle("notify__form--off", isOff);
                if (!isOff) updateHoursState();
            }
            if (offCb) {
                offCb.addEventListener("change", applyOffState);
            }
            function formatHour(h) {
                h = ((h % 24) + 24) % 24;
                if (h === 0) return "12 AM";
                if (h === 12) return "12 PM";
                if (h < 12) return h + " AM";
                return (h - 12) + " PM";
            }
            function rangeLength(start, end) {
                var diff = (end - start + 24) % 24;
                return diff === 0 ? 24 : diff;
            }
            var THUMB_W = 18;
            function thumbPos(h) {
                // Thumb-center position along the track for value h in [0, 23].
                // Browsers constrain the thumb so its center moves between
                // THUMB_W/2 and (trackWidth - THUMB_W/2).
                var pct = (h / 23) * 100;
                var px = 9 - (h / 23) * THUMB_W;
                var sign = px >= 0 ? " + " : " - ";
                return "calc(" + pct + "% " + sign + Math.abs(px) + "px)";
            }
            function spanWidth(diff) {
                // Width between two thumb-centers that are `diff` hours apart.
                var pct = (diff / 23) * 100;
                var px = (diff / 23) * THUMB_W;
                return "calc(" + pct + "% - " + px + "px)";
            }
            function updateHoursState() {
                if (!hoursEnabledCb || !startSlider || !endSlider) return;
                var enabled = hoursEnabledCb.checked;
                if (hoursPanel) hoursPanel.classList.toggle("notify__hours-panel--off", !enabled);
                startSlider.disabled = !enabled;
                endSlider.disabled = !enabled;
                var start = parseInt(startSlider.value, 10);
                var end = parseInt(endSlider.value, 10);
                var len = rangeLength(start, end);
                if (readout) {
                    if (start === end) {
                        readout.textContent = I18N.pick_different;
                    } else {
                        readout.textContent =
                            formatHour(start) + " – " + formatHour(end) +
                            " (" + len + " " + (len === 1 ? I18N.unit_hour : I18N.unit_hours) + ")";
                    }
                }
                if (bandA && bandB) {
                    if (start < end) {
                        bandA.style.left = thumbPos(start);
                        bandA.style.width = spanWidth(end - start);
                        bandB.style.left = "0";
                        bandB.style.width = "0";
                    } else if (start > end) {
                        bandA.style.left = thumbPos(start);
                        bandA.style.width = spanWidth(23 - start);
                        bandB.style.left = "9px";
                        bandB.style.width = spanWidth(end);
                    } else {
                        bandA.style.left = "0";
                        bandA.style.width = "0";
                        bandB.style.left = "0";
                        bandB.style.width = "0";
                    }
                }
                var invalid = enabled && (start === end || len > ACTIVE_HOURS_MAX);
                hoursInvalid = invalid;
                if (hoursError) {
                    if (invalid && start === end) {
                        hoursError.textContent = I18N.must_differ;
                        hoursError.hidden = false;
                    } else if (invalid) {
                        hoursError.textContent = I18N.range_max;
                        hoursError.hidden = false;
                    } else {
                        hoursError.hidden = true;
                    }
                }
                if (saveBtn) saveBtn.disabled = invalid;
            }
            if (tzInput && tzLabel) {
                var tz = "";
                try {
                    tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
                } catch (e) { tz = ""; }
                if (tz) tzInput.value = tz;
                tzLabel.textContent = tzInput.value
                    ? I18N.times_in.replace("%{tz}", tzInput.value)
                    : I18N.times_local;
            }
            if (hoursEnabledCb) hoursEnabledCb.addEventListener("change", updateHoursState);
            if (startSlider) startSlider.addEventListener("input", updateHoursState);
            if (endSlider) endSlider.addEventListener("input", updateHoursState);
            updateHoursState();
            applyOffState();
            function showToast(message, isError) {
                if (hideTimer) clearTimeout(hideTimer);
                toast.textContent = message;
                toast.classList.toggle("notify__toast--error", !!isError);
                toast.hidden = false;
                // Force a reflow so the transition runs on re-show.
                void toast.offsetWidth;
                toast.classList.add("notify__toast--visible");
                hideTimer = setTimeout(function () {
                    toast.classList.remove("notify__toast--visible");
                    setTimeout(function () { toast.hidden = true; }, 250);
                }, 3000);
            }
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                if (hoursInvalid && !(offCb && offCb.checked)) {
                    showToast(errorMessage, true);
                    return;
                }
                var data = new FormData(form);
                fetch(form.action, {
                    method: "POST",
                    body: data,
                    credentials: "same-origin",
                    headers: { "Accept": "application/json" },
                }).then(function (resp) {
                    if (resp.ok) {
                        var msg = (offCb && offCb.checked) ? offMessage : successMessage;
                        showToast(msg, false);
                    } else {
                        showToast(errorMessage, true);
                    }
                }).catch(function () {
                    showToast(errorMessage, true);
                });
            });
        })();
        </script>
    </body>
</html>
