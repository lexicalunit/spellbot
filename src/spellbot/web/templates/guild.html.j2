{% extends "record_base.html.j2" %}
{% from "motd_help.html.j2" import motd_placeholders with context %}
{% block title %}{{ guild.name | default(t("web.common.spellbot_server") , true) }}{% endblock %}
{% block heading %}{{ guild.name | default(t("web.common.spellbot_server") , true) }}{% endblock %}
{% block subtitle %}
    <div class="subtitle">
        <a href="/queues/g/{{ guild.xid }}">{{ t("web.nav.notification_preferences") }}</a>
        <span class="user-id">{{ guild.xid }}</span>
        &nbsp;<a href="https://discord.com/channels/{{ guild.xid }}" class="button">{{ t("web.common.jump_to_guild") | replace(" ", "&nbsp;") | safe }}</a>
        {%- if is_moderator %}&nbsp;<a href="/g/{{ guild.xid }}/analytics" class="button">{{ t("web.guild.view_analytics") }}</a>{%- endif %}
        &middot; {{ t("web.guild.channels_with_games", count=channels | length) }}
    </div>
{% endblock %}
{% block content %}
    {%- if not is_logged_in %}
        <div class="section">
            <div class="card">
                <p class="login-prompt">
                    {{ t("web.records.mod_manage_server") }}
                    <a href="{{ login_url }}" class="button">{{ t("web.common.login_with_discord") }}</a>
                </p>
            </div>
        </div>
    {%- endif %}
    {%- if is_owner %}
        <div class="section">
            <h2>{{ t("web.guild.owner_controls") }}</h2>
            <div class="card">
                <p class="owner-promote-status">
                    {{ t("web.guild.promotion_status", state=('<strong>' | safe) ~ (t("web.guild.promotion_enabled") if guild.promote else t("web.guild.promotion_disabled")) ~ ('</strong>' | safe)) | safe }}
                </p>
                <form method="post"
                      action="/g/{{ guild.xid }}/promote"
                      class="owner-promote-form">
                    <input type="hidden"
                           name="promote"
                           value="{{ 'false' if guild.promote else 'true' }}">
                    <button type="submit" class="button">
                        {{ t("web.guild.disable_promotion") if guild.promote else t("web.guild.enable_promotion") }}
                    </button>
                </form>
            </div>
        </div>
    {%- endif %}
    {%- if is_moderator and guild_settings %}
        <div class="section">
            <h2>{{ t("web.guild.settings_heading") }}</h2>
            <div class="card">
                <form method="post"
                      action="/g/{{ guild.xid }}/settings"
                      class="settings-form">
                    <div class="grid">
                        <div class="field">
                            <label for="guild-motd">{{ t("web.guild.motd") }}</label>
                            <p class="hint">{{ guild_help['motd'] }}</p>
                            <input type="text"
                                   id="guild-motd"
                                   name="motd"
                                   maxlength="255"
                                   value="{{ guild_settings.motd | default('', true) }}">
                            {{ motd_placeholders() }}
                        </div>
                        <div class="field">
                            <label for="guild-vc-category">{{ t("web.guild.suggest_voice_category") }}</label>
                            <p class="hint">{{ guild_help['suggest_voice_category'] }}</p>
                            <input type="text"
                                   id="guild-vc-category"
                                   name="suggest_voice_category"
                                   maxlength="100"
                                   value="{{ guild_settings.suggest_voice_category | default('', true) }}">
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="guild-show-links"
                                       name="show_links"
                                       value="true"
                                       {{ 'checked' if guild_settings.show_links else '' }}>
                                <label for="guild-show-links">{{ t("web.guild.show_links") }}</label>
                            </div>
                            <p class="hint">{{ guild_help['show_links'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="guild-voice-create"
                                       name="voice_create"
                                       value="true"
                                       {{ 'checked' if guild_settings.voice_create else '' }}>
                                <label for="guild-voice-create">{{ t("web.guild.voice_create") }}</label>
                            </div>
                            <p class="hint">{{ guild_help['voice_create'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="guild-max-bitrate"
                                       name="use_max_bitrate"
                                       value="true"
                                       {{ 'checked' if guild_settings.use_max_bitrate else '' }}>
                                <label for="guild-max-bitrate">{{ t("web.guild.use_max_bitrate") }}</label>
                            </div>
                            <p class="hint">{{ guild_help['use_max_bitrate'] }}</p>
                        </div>
                        <div class="field">
                            <div class="toggle-row">
                                <input type="checkbox"
                                       id="guild-mythic-track"
                                       name="enable_mythic_track"
                                       value="true"
                                       {{ 'checked' if guild_settings.enable_mythic_track else '' }}>
                                <label for="guild-mythic-track">{{ t("web.guild.enable_mythic_track") }}</label>
                            </div>
                            <p class="hint">{{ guild_help['enable_mythic_track'] }}</p>
                        </div>
                    </div>
                    <div class="actions">
                        <button type="submit" class="button">{{ t("web.guild.save") }}</button>
                        <a href="/g/{{ guild.xid }}/audit" class="button">{{ t("web.common.view_change_history") }}</a>
                    </div>
                </form>
            </div>
        </div>
    {%- endif %}
    {%- if is_moderator and guild_settings %}
        <div class="section">
            <div class="section-head">
                <h2>{{ t("web.guild.player_awards") }}</h2>
                <a href="/g/{{ guild.xid }}/awards" class="button">{{ t("web.guild.manage_awards") }}</a>
            </div>
            <div class="card">
                {%- if awards %}
                    <ul class="award-summary">
                        {% for award in awards %}
                            <li>{{ t("web.guild.award_summary", count=award.count, role=award.role) }}</li>
                        {% endfor %}
                    </ul>
                {%- else %}
                    <p class="empty">{{ t("web.guild.no_awards") }}</p>
                {%- endif %}
            </div>
        </div>
    {%- endif %}
    <div class="section">
        <h2>{{ t("web.guild.channels") }}</h2>
        {% if channels %}
            <div class="card">
                <table>
                    <thead>
                        <tr>
                            <th>{{ t("web.field.channel") }}</th>
                            <th>{{ t("web.field.channel_id") }}</th>
                            <th>{{ t("web.guild.games") }}</th>
                            <th>{{ t("web.guild.last_activity") }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for channel in channels %}
                            <tr>
                                <td data-label="{{ t('web.field.channel') }}">
                                    <a href="/g/{{ guild.xid }}/c/{{ channel.xid }}">#{{ channel.name | default(t("web.common.unknown_channel") , true) }}</a>
                                </td>
                                <td data-label="{{ t('web.field.channel_id') }}">
                                    <span class="id-copy">
                                        <span class="user-id">{{ channel.xid }}</span>
                                        <button type="button"
                                                class="copy"
                                                data-copy="{{ channel.xid }}"
                                                title="{{ t('web.common.copy_channel_id') }}">⎘</button>
                                    </span>
                                </td>
                                <td data-label="{{ t('web.guild.games') }}">{{ "{:,}".format(channel.games) }}</td>
                                <td data-label="{{ t('web.guild.last_activity') }}">
                                    {% if tz_offset and tz_name %}{{ channel.last_updated_at | humanize(tz_offset, tz_name) }}
                                        {% else %}<span class="timestamp">{{ channel.last_updated_at }}</span>{% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="card">
                <p class="empty">{{ t("web.guild.no_channels") }}</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
