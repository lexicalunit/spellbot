{% extends "record_base.html.j2" %}
{% from "motd_help.html.j2" import motd_placeholders %}
{% block title %}{{ guild.name | default('SpellBot Server', true) }}{% endblock %}
{% block heading %}{{ guild.name | default('SpellBot Server', true) }}{% endblock %}
{% block subtitle %}
<div class="subtitle">
    <a href="https://discord.com/channels/{{ guild.xid }}">Open server</a>
    &middot; <a href="/queues/g/{{ guild.xid }}">Notification preferences</a>
    <span class="user-id">{{ guild.xid }}</span>
    &middot; {{ channels | length }} channel{{ '' if channels | length == 1 else 's' }} with games
</div>
{% endblock %}
{% block content %}
{%- if not is_logged_in %}
<div class="section">
    <div class="card">
        <p class="login-prompt">
            Moderators can manage this server's settings here.
            <a href="{{ login_url }}" class="button">Log in with Discord</a>
        </p>
    </div>
</div>
{%- endif %}
{%- if is_owner %}
<div class="section">
    <h2>Owner Controls</h2>
    <div class="card">
        <p class="owner-promote-status">
            Public promotion is currently
            <strong>{{ 'enabled' if guild.promote else 'disabled' }}</strong>
            for this server.
        </p>
        <form method="post" action="/g/{{ guild.xid }}/promote" class="owner-promote-form">
            <input type="hidden" name="promote" value="{{ 'false' if guild.promote else 'true' }}">
            <button type="submit" class="button">
                {{ 'Disable promotion' if guild.promote else 'Enable promotion' }}
            </button>
        </form>
    </div>
</div>
{%- endif %}
{%- if is_moderator and guild_settings %}
<div class="section">
    <h2>Server Settings</h2>
    <div class="card">
        <form method="post" action="/g/{{ guild.xid }}/settings" class="settings-form">
            <div class="grid">
                <div class="field">
                    <label for="guild-motd">Message of the day</label>
                    <p class="hint">{{ guild_help['motd'] }}</p>
                    <input type="text" id="guild-motd" name="motd" maxlength="255"
                           value="{{ guild_settings.motd | default('', true) }}">
                    {{ motd_placeholders() }}
                </div>
                <div class="field">
                    <label for="guild-vc-category">Suggested voice category</label>
                    <p class="hint">{{ guild_help['suggest_voice_category'] }}</p>
                    <input type="text" id="guild-vc-category" name="suggest_voice_category" maxlength="100"
                           value="{{ guild_settings.suggest_voice_category | default('', true) }}">
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="guild-show-links" name="show_links" value="true"
                               {{ 'checked' if guild_settings.show_links else '' }}>
                        <label for="guild-show-links">Show game links publicly</label>
                    </div>
                    <p class="hint">{{ guild_help['show_links'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="guild-voice-create" name="voice_create" value="true"
                               {{ 'checked' if guild_settings.voice_create else '' }}>
                        <label for="guild-voice-create">Auto-create voice channels</label>
                    </div>
                    <p class="hint">{{ guild_help['voice_create'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="guild-max-bitrate" name="use_max_bitrate" value="true"
                               {{ 'checked' if guild_settings.use_max_bitrate else '' }}>
                        <label for="guild-max-bitrate">Use maximum bitrate</label>
                    </div>
                    <p class="hint">{{ guild_help['use_max_bitrate'] }}</p>
                </div>
                <div class="field">
                    <div class="toggle-row">
                        <input type="checkbox" id="guild-mythic-track" name="enable_mythic_track" value="true"
                               {{ 'checked' if guild_settings.enable_mythic_track else '' }}>
                        <label for="guild-mythic-track">Enable mythic track</label>
                    </div>
                    <p class="hint">{{ guild_help['enable_mythic_track'] }}</p>
                </div>
            </div>
            <div class="actions">
                <button type="submit" class="button">Save server settings</button>
                <a href="/g/{{ guild.xid }}/audit" class="button">View change history</a>
            </div>
        </form>
    </div>
</div>
{%- endif %}
{%- if is_moderator and guild_settings %}
{% macro award_fields(award) %}
<div class="grid">
    <div class="field">
        <label>Games required</label>
        <p class="hint">{{ award_help['count'] }}</p>
        <input type="number" name="count" min="1" required
               value="{{ award.count if award else '' }}">
    </div>
    <div class="field">
        <label>Role</label>
        <p class="hint">{{ award_help['role'] }}</p>
        <input type="text" name="role" maxlength="{{ award_role_max }}" required
               value="{{ award.role if award else '' }}">
    </div>
    <div class="field">
        <label>Message</label>
        <p class="hint">{{ award_help['message'] }}</p>
        <input type="text" name="message" maxlength="{{ award_message_max }}"
               value="{{ award.message if award else '' }}">
    </div>
    <div class="field">
        <div class="toggle-row">
            <input type="checkbox" name="repeating" value="true"
                   {{ 'checked' if award and award.repeating else '' }}>
            <label>Repeating</label>
        </div>
        <p class="hint">{{ award_help['repeating'] }}</p>
    </div>
    <div class="field">
        <div class="toggle-row">
            <input type="checkbox" name="remove" value="true"
                   {{ 'checked' if award and award.remove else '' }}>
            <label>Remove role instead of giving</label>
        </div>
        <p class="hint">{{ award_help['remove'] }}</p>
    </div>
    <div class="field">
        <div class="toggle-row">
            <input type="checkbox" name="verified_only" value="true"
                   {{ 'checked' if award and award.verified_only else '' }}>
            <label>Verified users only</label>
        </div>
        <p class="hint">{{ award_help['verified_only'] }}</p>
    </div>
    <div class="field">
        <div class="toggle-row">
            <input type="checkbox" name="unverified_only" value="true"
                   {{ 'checked' if award and award.unverified_only else '' }}>
            <label>Unverified users only</label>
        </div>
        <p class="hint">{{ award_help['unverified_only'] }}</p>
    </div>
</div>
{% endmacro %}
<div class="section">
    <h2>Player Awards</h2>
    {%- if award_error %}
    <div class="card award-error">{{ award_error }}</div>
    {%- endif %}
    {% for award in awards %}
    <div class="card">
        <form method="post" action="/g/{{ guild.xid }}/awards/{{ award.id }}/update" class="settings-form">
            {{ award_fields(award) }}
            <div class="actions">
                <button type="submit" class="button">Save award</button>
            </div>
        </form>
        <form method="post" action="/g/{{ guild.xid }}/awards/{{ award.id }}/delete" class="settings-form"
              onsubmit="return confirm('Delete this award?');">
            <div class="actions">
                <button type="submit" class="button button-danger">Delete award</button>
            </div>
        </form>
    </div>
    {% else %}
    <div class="card">
        <p class="empty">No awards configured yet. Add one below.</p>
    </div>
    {% endfor %}
    <div class="card">
        <h3>Add an award</h3>
        <form method="post" action="/g/{{ guild.xid }}/awards/add" class="settings-form">
            {{ award_fields(none) }}
            <div class="actions">
                <button type="submit" class="button">Add award</button>
            </div>
        </form>
    </div>
</div>
{%- endif %}
<div class="section">
    <h2>Channels</h2>
    {% if channels %}
    <div class="card">
        <table>
            <thead>
                <tr><th>Channel</th><th>Channel ID</th><th>Games</th><th>Last Activity</th></tr>
            </thead>
            <tbody>
                {% for channel in channels %}
                <tr>
                    <td data-label="Channel">
                        <a href="/g/{{ guild.xid }}/c/{{ channel.xid }}">#{{ channel.name | default('Unknown Channel', true) }}</a>
                    </td>
                    <td data-label="Channel ID">
                        <span class="id-copy">
                            <span class="user-id">{{ channel.xid }}</span>
                            <button type="button" class="copy" data-copy="{{ channel.xid }}" title="Copy Channel ID">⎘</button>
                        </span>
                    </td>
                    <td data-label="Games">{{ "{:,}".format(channel.games) }}</td>
                    <td data-label="Last Activity">
                        {% if tz_offset and tz_name %}{{ channel.last_updated_at | humanize(tz_offset, tz_name) }}
                        {% else %}<span class="timestamp">{{ channel.last_updated_at }}</span>{% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card">
        <p class="empty">No channels with games yet.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
