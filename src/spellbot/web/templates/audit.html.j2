{% extends "record_base.html.j2" %}
{% block title %}Settings History{% endblock %}
{% block heading %}Settings change history{% endblock %}
{% block subtitle %}
<div class="subtitle">
    <a href="{{ back_url }}">&larr; Back</a>
</div>
{% endblock %}
{% block content %}
<div class="section">
    <h2>{{ scope | capitalize }} settings changes <span class="count">({{ total }})</span></h2>
    <div class="card">
        {% if rows %}
        <table>
            <thead>
                <tr>
                    <th>When</th>
                    <th>Who</th>
                    <th>Source</th>
                    <th>Setting</th>
                    <th>Old</th>
                    <th>New</th>
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                <tr>
                    <td data-label="When" class="timestamp">{{ row.when }}</td>
                    <td data-label="Who">{{ row.who }}</td>
                    <td data-label="Source">{{ row.source }}</td>
                    <td data-label="Setting">{{ row.setting }}</td>
                    <td data-label="Old">{{ row.old }}</td>
                    <td data-label="New">{{ row.new }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty">No settings changes have been recorded yet.</div>
        {% endif %}
    </div>
</div>
{% endblock %}
