{% extends "record_base.html.j2" %}
{% from "record_filters.html.j2" import sort_header, filter_form %}
{% block title %}User Records — {{ target_name or target_xid }}{% endblock %}
{% block heading %}User Records: {{ target_name or 'Unknown User' }}{% endblock %}
{% block subtitle %}
<div class="subtitle">
    <span class="id-copy">
        <span class="user-id">{{ target_xid }}</span>
        <button type="button" class="copy" data-copy="{{ target_xid }}" title="Copy User ID">⎘</button>
    </span>
</div>
{% endblock %}
{% block content %}
{%- if is_own_profile %}
<div class="section">
    <h2>Blocked Users</h2>
    {%- if block_error %}
    <div class="card award-error">{{ block_error }}</div>
    {%- endif %}
    <div class="card">
        <p class="hint">
            Players you block can't join your games, and you can't join theirs. This list is private to you.
        </p>
        {% if blocked_users %}
        <table>
            <thead>
                <tr><th>User</th><th>User ID</th><th></th></tr>
            </thead>
            <tbody>
                {% for blocked in blocked_users %}
                <tr>
                    <td data-label="User">{{ blocked.name | default('Unknown User', true) }}</td>
                    <td data-label="User ID">
                        <span class="id-copy">
                            <span class="user-id">{{ blocked.xid }}</span>
                            <button type="button" class="copy" data-copy="{{ blocked.xid }}" title="Copy User ID">⎘</button>
                        </span>
                    </td>
                    <td data-label="">
                        <form method="post" action="/u/{{ target_xid }}/blocks/{{ blocked.xid }}/remove">
                            <button type="submit" class="button button-danger">Unblock</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p class="empty">You haven't blocked anyone.</p>
        {% endif %}
        <form method="post" action="/u/{{ target_xid }}/blocks/add" class="settings-form block-add-form">
            <div class="field">
                <label for="block-target">Block a user</label>
                <p class="hint">Enter the Discord user ID (or name) of the player you want to block.</p>
                <input type="text" id="block-target" name="target" maxlength="100" required
                       placeholder="Discord user ID or name">
            </div>
            <div class="actions">
                <button type="submit" class="button">Block user</button>
            </div>
        </form>
    </div>
</div>
{%- elif not is_logged_in %}
<div class="section">
    <div class="card">
        <p class="login-prompt">
            Log in to view and manage your own block list.
            <a href="{{ login_url }}" class="button">Log in with Discord</a>
        </p>
    </div>
</div>
{%- endif %}
<div class="section">
    <h2>Games <span class="count">({{ total }} matching)</span></h2>
    {{ filter_form(true, format_choices, bracket_choices, filters) }}
    <div class="card">
        {% if records %}
        <table>
            <thead>
                <tr>
                    <th>{{ sort_header('id', 'Game', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('updated_at', 'Time', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('guild_name', 'Guild', sort_by, sort_dir, filters) }}</th>
                    <th>Channel</th>
                    <th>{{ sort_header('format', 'Format', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('seats', 'Seats', sort_by, sort_dir, filters) }}</th>
                    <th>{{ sort_header('bracket', 'Bracket', sort_by, sort_dir, filters) }}</th>
                    <th>Locale</th>
                    <th>Link</th>
                    <th>Players</th>
                    <th>Jump</th>
                </tr>
            </thead>
            <tbody id="rows">
                {% for record in records %}
                <tr>
                    <td data-label="Game"><a href="/game/{{ record.id }}">SB#{{ record.id }}</a></td>
                    {% if tz_offset and tz_name %}
                    <td data-label="Time">{{ record.updated_at | humanize(tz_offset, tz_name) }}</td>
                    {% else %}
                    <td data-label="Time" class="timestamp">{{ record.updated_at }}</td>
                    {% endif %}
                    <td data-label="Guild"><a href="https://discord.com/channels/{{ record.guild }}">{{ record.guild_name }}</a></td>
                    <td data-label="Channel"><a href="https://discord.com/channels/{{ record.guild }}/{{ record.channel }}">#{{ record.channel_name }}</a></td>
                    <td data-label="Format">{{ record.format }}</td>
                    <td data-label="Seats">{{ record.seats }}</td>
                    <td data-label="Bracket">{{ record.bracket }}</td>
                    <td data-label="Locale">{{ record.locale }}</td>
                    <td data-label="Link">
                        {% if record.link %}<a href="{{ record.link }}">Open in {{ record.service }}</a>{% else %}&mdash;{% endif %}
                    </td>
                    <td data-label="Players">
                        <div class="players">
                            {% for name, data in record.scores.items() %}
                            <div class="player">
                                <span class="name">{{ name | default('Unknown User', true) }}</span>
                                <span class="id-copy">
                                    <span class="user-id">{{ data[0] }}</span>
                                    <button type="button" class="copy" data-copy="{{ data[0] }}" title="Copy User ID">⎘</button>
                                </span>
                            </div>
                            {% endfor %}
                        </div>
                    </td>
                    <td data-label="Jump"><a href="https://discord.com/channels/{{ record.guild }}/{{ record.channel }}/{{ record.message }}" class="button">Jump&nbsp;to&nbsp;game</a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty">No games found for this user.</div>
        {% endif %}
    </div>
</div>
{% endblock %}
