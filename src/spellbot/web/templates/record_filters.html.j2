{% macro sort_header(key, label, sort_by, sort_dir, filters) %}
{%- if sort_by == key -%}
  {%- set next_dir = 'asc' if sort_dir == 'desc' else 'desc' -%}
{%- else -%}
  {%- set next_dir = 'desc' -%}
{%- endif -%}
{%- set qs = [] -%}
{%- for k in ('with_player', 'guild', 'from', 'to') -%}
  {%- if filters.get(k) %}{% set _ = qs.append((k, filters[k])) %}{% endif -%}
{%- endfor -%}
{%- for v in filters.get('formats') or [] %}{% set _ = qs.append(('formats', v|string)) %}{% endfor -%}
{%- for v in filters.get('brackets') or [] %}{% set _ = qs.append(('brackets', v|string)) %}{% endfor -%}
{%- set _ = qs.append(('sort', key)) -%}
{%- set _ = qs.append(('dir', next_dir)) -%}
<a class="sort" href="?{{ qs | urlencode }}">{{ label }}{% if sort_by == key %}<span class="arrow">{% if sort_dir == 'asc' %}&#9650;{% else %}&#9660;{% endif %}</span>{% endif %}</a>
{%- endmacro %}

{% macro filter_form(show_guild, format_choices, bracket_choices, filters) %}
<form method="get" class="filters">
    <div class="row">
        <div class="field">
            <label for="f-with-player">Player (name or ID)</label>
            <input type="text" id="f-with-player" name="with_player" value="{{ filters.with_player or '' }}" placeholder="e.g. amy or 12345">
        </div>
        {% if show_guild %}
        <div class="field">
            <label for="f-guild">Guild (name or ID)</label>
            <input type="text" id="f-guild" name="guild" value="{{ filters.guild or '' }}" placeholder="e.g. my-guild or 67890">
        </div>
        {% endif %}
        <div class="field">
            <label for="f-from">From</label>
            <input type="date" id="f-from" name="from" value="{{ filters['from'] or '' }}">
        </div>
        <div class="field">
            <label for="f-to">To</label>
            <input type="date" id="f-to" name="to" value="{{ filters.to or '' }}">
        </div>
    </div>
    <div class="row">
        <div class="field">
            <label for="f-formats">Format(s)</label>
            <select id="f-formats" name="formats" multiple size="6">
                {% for c in format_choices %}
                <option value="{{ c.value }}" {% if c.value in filters.formats %}selected{% endif %}>{{ c.label }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="field">
            <label for="f-brackets">Bracket(s)</label>
            <select id="f-brackets" name="brackets" multiple size="6">
                {% for c in bracket_choices %}
                <option value="{{ c.value }}" {% if c.value in filters.brackets %}selected{% endif %}>{{ c.label }}</option>
                {% endfor %}
            </select>
        </div>
    </div>
    <div class="actions">
        <button type="submit" class="button">Apply filters</button>
        <a href="?" class="button">Reset</a>
    </div>
</form>
{% endmacro %}
