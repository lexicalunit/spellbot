<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Active Queues — SpellBot</title>
    <meta name="description" content="Join an active Magic: The Gathering queue powered by SpellBot.">
    <meta name="theme-color" content="#1a202c">
    <meta http-equiv="refresh" content="60">
    <link rel="icon" type="image/x-icon" href="https://spellbot.io/favicon.ico">
    <style>
        {% include "queues.css" %}
    </style>
</head>
<body>
    <div class="container">
        <header class="page-header">
            <a href="https://spellbot.io/">
                <img class="logo" alt="SpellBot" src="https://spellbot.io/assets/img/avatar-icon.png">
            </a>
            <h1>Active Queues</h1>
            <div class="page-header__stat" title="Pending queues plus games started in the last 2 hours">
                <span class="page-header__stat-value">{{ "{:,}".format(stats.active_games) }}</span>
                <span class="page-header__stat-label">Active Games</span>
            </div>
        </header>

        {% set show_filter_bar = rows or games or viewer.logged_in or viewer.login_enabled %}
        {% if show_filter_bar %}
        <div class="filters" role="group" aria-label="Filter queues">
            {% if rows or games %}
            <label class="filters__field">
                <span class="filters__label">Format</span>
                <select id="filter-format" class="filters__select">
                    <option value="">All formats</option>
                    {% for f in formats %}
                    <option value="{{ f }}">{{ f }}</option>
                    {% endfor %}
                </select>
            </label>
            <label class="filters__field">
                <span class="filters__label">Bracket</span>
                <select id="filter-bracket" class="filters__select">
                    <option value="">All brackets</option>
                    {% for b in brackets %}
                    <option value="{{ b }}">{{ b }}</option>
                    {% endfor %}
                </select>
            </label>
            <label class="filters__field">
                <span class="filters__label">Language</span>
                <select id="filter-language" class="filters__select">
                    <option value="">All languages</option>
                    {% for l in languages %}
                    <option value="{{ l }}">{{ l }}</option>
                    {% endfor %}
                </select>
            </label>
            {% endif %}
            <div class="filters__viewer">
                {% if viewer.logged_in %}
                <label class="filters__mine">
                    <input
                        type="checkbox"
                        id="filter-mine"
                        {% if viewer.my_filter_on %}checked{% endif %}
                    >
                    <span>Only servers you've played in</span>
                </label>
                <div class="filters__identity">
                    <span class="filters__identity-name">Logged in as <strong>{{ viewer.name }}</strong></span>
                    <form method="post" action="/queues/logout" class="filters__logout-form">
                        <button type="submit" class="filters__logout">Log out</button>
                    </form>
                </div>
                {% elif viewer.login_enabled %}
                <a class="filters__login" href="/queues/login" rel="nofollow">
                    Log in with Discord to filter to your servers
                </a>
                {% endif %}
            </div>
            {% if rows or games %}
            <p id="filter-empty" class="filters__empty" hidden>
                No queues match the selected filters.
            </p>
            {% endif %}
        </div>
        {% endif %}

        {% if viewer.logged_in and played_guilds %}
        <div class="gallery-divider" role="separator" aria-label="Servers you've played in">
            <span class="gallery-divider__label gallery-divider__label--played">Your Servers</span>
        </div>
        <ul class="played-list">
            {% for pg in played_guilds %}
            <li>
                <a
                    class="played-list__row"
                    href="/queues/g/{{ pg.guild_xid }}"
                    aria-label="{% if pg.notifications_on %}Manage{% else %}Setup{% endif %} notifications for {{ pg.guild_name or 'this server' }}"
                    data-tooltip="{% if pg.notifications_on %}Manage{% else %}Setup{% endif %} notifications"
                >
                    <img
                        class="played-list__logo"
                        src="{{ pg.logo }}"
                        alt=""
                        onerror="this.onerror=null;this.src='{{ default_logo }}';"
                        loading="lazy"
                    >
                    <span class="played-list__name">{{ pg.guild_name or "SpellBot Server" }}</span>
                    <span class="played-list__action{% if pg.notifications_on %} played-list__action--on{% endif %}" aria-hidden="true">
                        <svg class="played-list__action-icon" viewBox="0 0 24 24" width="14" height="14" focusable="false">
                            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9z M10 21a2 2 0 0 0 4 0"/>
                        </svg>
                        <span class="played-list__action-label">{% if pg.notifications_on %}On{% else %}Notifications{% endif %}</span>
                    </span>
                </a>
            </li>
            {% endfor %}
        </ul>
        {% endif %}

        {% if not rows and not games %}
        <div class="empty">
            {% if viewer.my_filter_on %}
            No active queues right now in servers you've played in. Uncheck the filter to see all servers.
            {% else %}
            No active queues right now. Check back in a moment, or run <code>/lfg</code> in your Discord server to start one.
            {% endif %}
        </div>
        {% else %}
        {% if rows %}
        {% if viewer.logged_in and played_guilds %}
        <div class="gallery-divider" role="separator" aria-label="Active queues">
            <span class="gallery-divider__label">Active Queues</span>
        </div>
        {% endif %}
        <section class="gallery">
            {% for row in rows %}
            <article class="queue-card" data-format="{{ row.format }}" data-bracket="{{ row.bracket }}" data-language="{{ row.language }}">
                <div class="queue-card__header">
                    <img
                        class="queue-card__logo"
                        src="{{ row.logo }}"
                        alt="{{ row.guild_name }}"
                        onerror="this.onerror=null;this.src='{{ default_logo }}';"
                        loading="lazy"
                    >
                    <div class="queue-card__heading">
                        <h2 class="queue-card__server"><a class="queue-card__server-link" href="/g/{{ row.guild_xid }}">{{ row.guild_name or "SpellBot Server" }}</a></h2>
                        <div class="queue-card__actions">
                            <a
                                class="queue-card__notify"
                                href="/queues/g/{{ row.guild_xid }}"
                                aria-label="Setup notifications for this server"
                                data-tooltip="Setup notifications"
                            >
                                <svg class="queue-card__notify-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9z M10 21a2 2 0 0 0 4 0"/>
                                </svg>
                            </a>
                            <button
                                type="button"
                                class="queue-card__copy"
                                data-copy="{{ row.guild_xid }}"
                                aria-label="Copy server ID"
                                data-tooltip="Copy server ID"
                            >
                                <svg class="queue-card__copy-icon queue-card__copy-icon--copy" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 9h10v12H9z M5 15V3h10v4"/>
                                </svg>
                                <svg class="queue-card__copy-icon queue-card__copy-icon--check" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <dl class="queue-card__meta">
                    <div><dt>Format</dt><dd>{{ row.format }}</dd></div>
                    <div><dt>Bracket</dt><dd>{{ row.bracket }}</dd></div>
                    <div><dt>Service</dt><dd>{{ row.service }}</dd></div>
                    <div><dt>Language</dt><dd>{{ row.language }}</dd></div>
                    <div><dt>Wait</dt><dd>{{ row.wait_seconds | wait }}</dd></div>
                    <div>
                        <dt>Players</dt>
                        <dd><span class="players-badge">{{ row.players }} / {{ row.seats }}</span></dd>
                    </div>
                </dl>
                <a class="queue-card__cta" href="{{ row.jump_url }}" target="_blank" rel="noopener noreferrer">
                    Jump to Game →
                </a>
            </article>
            {% endfor %}
        </section>
        {% endif %}
        {% if games %}
        <div class="gallery-divider" role="separator" aria-label="Recently started games">
            <span class="gallery-divider__label">Recently Started</span>
        </div>
        <section class="gallery gallery--started">
            {% for game in games %}
            <article class="queue-card queue-card--started" data-format="{{ game.format }}" data-bracket="{{ game.bracket }}" data-language="{{ game.language }}">
                <div class="queue-card__header">
                    <img
                        class="queue-card__logo"
                        src="{{ game.logo }}"
                        alt="{{ game.guild_name }}"
                        onerror="this.onerror=null;this.src='{{ default_logo }}';"
                        loading="lazy"
                    >
                    <div class="queue-card__heading">
                        <h2 class="queue-card__server"><a class="queue-card__server-link" href="/g/{{ game.guild_xid }}">{{ game.guild_name or "SpellBot Server" }}</a></h2>
                        <div class="queue-card__actions">
                            <a
                                class="queue-card__notify"
                                href="/queues/g/{{ game.guild_xid }}"
                                aria-label="Setup notifications for this server"
                                data-tooltip="Setup notifications"
                            >
                                <svg class="queue-card__notify-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9z M10 21a2 2 0 0 0 4 0"/>
                                </svg>
                            </a>
                            <button
                                type="button"
                                class="queue-card__copy"
                                data-copy="{{ game.guild_xid }}"
                                aria-label="Copy server ID"
                                data-tooltip="Copy server ID"
                            >
                                <svg class="queue-card__copy-icon queue-card__copy-icon--copy" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 9h10v12H9z M5 15V3h10v4"/>
                                </svg>
                                <svg class="queue-card__copy-icon queue-card__copy-icon--check" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <dl class="queue-card__meta">
                    <div><dt>Format</dt><dd>{{ game.format }}</dd></div>
                    <div><dt>Bracket</dt><dd>{{ game.bracket }}</dd></div>
                    <div><dt>Service</dt><dd>{{ game.service }}</dd></div>
                    <div><dt>Language</dt><dd>{{ game.language }}</dd></div>
                    <div><dt>Started</dt><dd>{{ game.started_seconds_ago | wait }} ago</dd></div>
                    <div>
                        <dt>Players</dt>
                        <dd><span class="players-badge">{{ game.seats }} / {{ game.seats }}</span></dd>
                    </div>
                </dl>
                <a class="queue-card__cta" href="{{ game.jump_url }}" target="_blank" rel="noopener noreferrer">
                    Jump to Channel →
                </a>
            </article>
            {% endfor %}
        </section>
        {% endif %}
        <script>
            (function () {
                var formatSelect = document.getElementById("filter-format");
                var bracketSelect = document.getElementById("filter-bracket");
                var languageSelect = document.getElementById("filter-language");
                var emptyMsg = document.getElementById("filter-empty");
                var cards = document.querySelectorAll(".gallery .queue-card");
                function apply() {
                    var fmt = formatSelect.value;
                    var brk = bracketSelect.value;
                    var lng = languageSelect.value;
                    var visible = 0;
                    cards.forEach(function (card) {
                        var match =
                            (!fmt || card.dataset.format === fmt) &&
                            (!brk || card.dataset.bracket === brk) &&
                            (!lng || card.dataset.language === lng);
                        card.hidden = !match;
                        if (match) visible++;
                    });
                    emptyMsg.hidden = visible !== 0;
                }
                formatSelect.addEventListener("change", apply);
                bracketSelect.addEventListener("change", apply);
                languageSelect.addEventListener("change", apply);
            })();
            (function () {
                var buttons = document.querySelectorAll(".queue-card__copy");
                buttons.forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        var value = btn.dataset.copy || "";
                        var done = function () {
                            btn.dataset.copied = "true";
                            window.setTimeout(function () {
                                delete btn.dataset.copied;
                            }, 1200);
                        };
                        if (navigator.clipboard && navigator.clipboard.writeText) {
                            navigator.clipboard.writeText(value).then(done, function () {});
                        } else {
                            var ta = document.createElement("textarea");
                            ta.value = value;
                            ta.setAttribute("readonly", "");
                            ta.style.position = "absolute";
                            ta.style.left = "-9999px";
                            document.body.appendChild(ta);
                            ta.select();
                            try { document.execCommand("copy"); done(); } catch (e) {}
                            document.body.removeChild(ta);
                        }
                    });
                });
            })();
        </script>
        {% endif %}
        {% if viewer.logged_in %}
        <script>
            (function () {
                var mine = document.getElementById("filter-mine");
                if (!mine) return;
                mine.addEventListener("change", function () {
                    var url = new URL(window.location.href);
                    if (mine.checked) {
                        url.searchParams.set("my", "1");
                    } else {
                        url.searchParams.delete("my");
                    }
                    window.location.assign(url.toString());
                });
            })();
        </script>
        {% endif %}

        <footer class="page-footer">
            <p>Powered by <a href="https://spellbot.io/">SpellBot</a>.</p>
            <span class="updated">Auto-refreshing every 60 seconds.</span>
        </footer>
    </div>
</body>
</html>
