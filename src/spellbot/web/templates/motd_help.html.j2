{# Shared reference for the placeholders supported in server and channel MOTDs. #}
{% macro motd_placeholders() %}
<details class="motd-help">
    <summary>{{ t("web.motd.available") }}</summary>
    <p class="hint">{{ t("web.motd.intro") }}</p>
    <ul class="motd-placeholders">
        <li><code>${game_id}</code> — {{ t("web.motd.game_id") }}</li>
        <li><code>${game_format}</code> — {{ t("web.motd.game_format") }}</li>
        <li><code>${game_bracket}</code> — {{ t("web.motd.game_bracket") }}</li>
        <li><code>${game_start}</code> — {{ t("web.motd.game_start") }}</li>
        <li><code>${player_name_1}</code>, <code>${player_name_2}</code>, … — {{ t("web.motd.player_names") }}</li>
    </ul>
</details>
{% endmacro %}
